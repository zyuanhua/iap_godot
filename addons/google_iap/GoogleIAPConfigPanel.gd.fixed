func _on_clear_log():
	_append_log(_log("log.log_cleared"))
	log_text.text = ""
	_append_log(_log("log.log_cleared"))

func _on_export_log():
	_append_log(_log("log.click_export_log"))
	
	var date_str = Time.get_datetime_string_from_system().replace(" ", "_").replace(":", "-")
	var default_name = "iap_log_%s.txt" % date_str
	
	DisplayServer.file_dialog_show(
		_t("filedialog.title.export_log"),
		"",
		default_name,
		false,
		DisplayServer.FILE_DIALOG_MODE_SAVE_FILE,
		PackedStringArray(["*.txt"]),
		_on_export_log_file_selected
	)

func _on_export_log_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int):
	if not status or selected_paths.is_empty():
		_append_log(_log("log.log_export_cancelled"))
		return
	
	var file_path = selected_paths[0]
	
	var file = FileAccess.open(file_path, FileAccess.WRITE)
	if file:
		file.store_string(log_text.text)
		file.close()
		_append_log(_log("log.log_exported_to_detail", [file_path]))
	else:
		_append_log(_log("log.error_save_log_failed", [file_path]))

# ===================== 忙篓隆氓聺聴6茂录職忙聹聧氓聤隆莽芦炉茅聟聧莽陆庐氓聦?=====================
func _on_server_provider_selected(index: int):
	_append_log(_log("log.switch_provider_config", [server_provider.get_item_text(index)]))
	
	google_config_container.visible = (index == 0)
	apple_config_container.visible = (index == 1)
	huawei_config_container.visible = (index == 2)

func _collect_server_config():
	var provider_name = server_provider.get_item_text(server_provider.selected)
	
	server_config = {
		"provider": provider_name,
		"environment": server_env.get_item_text(server_env.selected),
		"google": {
			"key_path": google_key_path.text,
			"package_name": google_package_name.text
		},
		"apple": {
			"issuer_id": apple_issuer_id.text,
			"key_id": apple_key_id.text,
			"bundle_id": apple_bundle_id.text,
			"key_path": apple_key_path.text
		},
		"huawei": {
			"api_key": huawei_api_key.text,
			"app_id": huawei_app_id.text
		}
	}

func _load_config_to_ui(config: Dictionary):
	if config.has("environment"):
		var env_index = -1
		for i in range(server_env.item_count):
			if server_env.get_item_text(i) == config["environment"]:
				env_index = i
				break
		if env_index >= 0:
			server_env.selected = env_index
	
	if config.has("google"):
		var google = config["google"]
		if google is Dictionary:
			google_key_path.text = google.get("key_path", "")
			google_package_name.text = google.get("package_name", "")
	
	if config.has("apple"):
		var apple = config["apple"]
		if apple is Dictionary:
			apple_issuer_id.text = apple.get("issuer_id", "")
			apple_key_id.text = apple.get("key_id", "")
			apple_bundle_id.text = apple.get("bundle_id", "")
			apple_key_path.text = apple.get("key_path", "")
	
	if config.has("huawei"):
		var huawei = config["huawei"]
		if huawei is Dictionary:
			huawei_api_key.text = huawei.get("api_key", "")
			huawei_app_id.text = huawei.get("app_id", "")

