# ===================== 忙篓隆氓聺聴3茂录職SKU莽庐隆莽聬聠氓聦?=====================
func _get_status_text(status: String) -> String:
	match status:
		"active":
			return "莽聰聼忙聲聢盲赂?
		"inactive":
			return "氓路虏氓聛聹莽聰?
		"pending":
			return "氓戮聟莽聰聼忙聲?
		_:
			return "忙聹陋莽聼楼"

func _get_status_color(status: String) -> Color:
	match status:
		"active":
			return Color(0, 0.8, 0)
		"inactive":
			return Color(0.8, 0, 0)
		"pending":
			return Color(0.8, 0.6, 0)
		_:
			return Color(0.5, 0.5, 0.5)

func _on_provider_filter_changed(index: int):
	_append_log(_log("log.sku_provider_filter", [sku_provider_filter.get_item_text(index)]))
	_refresh_sku_tree()

func _on_show_inactive_toggled(checked: bool):
	_append_log(_log("log.inactive_sku_display", [("氓录聙氓聬? if checked else "氓聟鲁茅聴颅")]))
	_refresh_sku_tree()

func _refresh_sku_tree():
	sku_tree.clear()
	
	var filter_provider = ""
	if sku_provider_filter.selected > 0:
		filter_provider = sku_provider_filter.get_item_text(sku_provider_filter.selected)
	
	var show_inactive = show_inactive_checkbox.button_pressed
	
	for i in range(sku_database.size()):
		var sku = sku_database[i]
		
		if filter_provider != "" and sku.provider != filter_provider:
			continue
		
		if sku.status == "inactive" and not show_inactive:
			continue
		
		var item = sku_tree.create_item()
		item.set_text(0, sku.sku_id)
		item.set_text(1, sku.sku_name)
		item.set_text(2, sku.sku_price)
		item.set_text(3, sku.provider)
		item.set_text(4, _get_status_text(sku.status))
		item.set_custom_color(4, _get_status_color(sku.status))
		item.set_meta("index", i)

func _refresh_test_sku_option():
	test_sku_option.clear()
	for sku in sku_database:
		if sku.status == "active" or sku.status == "pending":
			test_sku_option.add_item("%s (%s)" % [sku.sku_name, sku.sku_id])

func _on_sku_selected():
	if currently_editing_index >= 0:
		_exit_edit_mode()
	
	var selected = sku_tree.get_selected()
	if selected:
		btn_edit_sku.disabled = false
		btn_deactivate_sku.disabled = false
		btn_activate_sku.disabled = false
	else:
		btn_edit_sku.disabled = true
		btn_deactivate_sku.disabled = true
		btn_activate_sku.disabled = true

func _exit_edit_mode():
	currently_editing_index = -1
	btn_update_sku.disabled = true
	btn_add_sku.disabled = false
	btn_edit_sku.text = _t("module3.btn.edit")
	sku_id_edit.editable = true
	sku_id_edit.clear()
	sku_name_edit.clear()
	sku_price_edit.clear()
	sku_provider_option.selected = -1
	
	var selected = sku_tree.get_selected()
	if not selected:
		btn_edit_sku.disabled = true
		btn_deactivate_sku.disabled = true
		btn_activate_sku.disabled = true
	else:
		btn_edit_sku.disabled = false
		btn_deactivate_sku.disabled = false
		btn_activate_sku.disabled = false
	
	_append_log(_log("log.exit_edit_mode"))

func _on_add_sku():
	_append_log(_log("log.click_add_sku"))
	
	if currently_editing_index >= 0:
		_append_log(_log("log.exit_edit_mode"))
		_exit_edit_mode()
		return
	
	var id = sku_id_edit.text.strip_edges()
	var name = sku_name_edit.text.strip_edges()
	var price = sku_price_edit.text.strip_edges()
	var provider_index = sku_provider_option.selected
	var provider = sku_provider_option.get_item_text(provider_index) if provider_index >= 0 else "Google"
	
	if id.is_empty():
		_append_log(_log("log.error_sku_id_empty"))
		return
	
	if name.is_empty():
		_append_log(_log("log.error_sku_name_empty"))
		return
	
	if not price.is_valid_float():
		_append_log(_log("log.error_price_invalid"))
		return
	
	for sku in sku_database:
		if sku.sku_id == id:
			_append_log(_log("log.error_sku_exists", [id]))
			return
	
	var new_sku = IAPSKUData.new(id, name, price, provider, "active")
	sku_database.append(new_sku)
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	
	# 忙赂聟莽漏潞忙聣聙忙聹聣猫戮聯氓聟楼忙隆聠
	sku_id_edit.text = ""
	sku_name_edit.text = ""
	sku_price_edit.text = ""
	sku_provider_option.selected = 0  # 猫庐戮盲赂潞茅禄聵猫庐陇氓聙?Google
	
	# 莽隆庐盲驴聺 ID 氓聫炉莽录聳猫戮?
	sku_id_edit.editable = true
	
	_append_log(_log("log.sku_added_success", [id, name]))

# ==================== SKU 莽庐隆莽聬聠氓聤聼猫聝陆茂录聢盲禄聟猫掳聝猫炉聲忙篓隆氓录聫茂录?====================
func _on_add_new_sku():
	if not is_sku_debug_mode:
		_append_log(_log("log.debug_mode_only"))
		return
	
	_append_log(_log("log.click_add_sku_confirm"))
	
	var id = sku_id_edit.text.strip_edges()
	var name = sku_name_edit.text.strip_edges()
	var price = sku_price_edit.text.strip_edges()
	var provider_index = sku_provider_option.selected
	var provider = sku_provider_option.get_item_text(provider_index) if provider_index >= 0 else "Google"
	
	if id.is_empty():
		_append_log(_log("log.error_sku_id_empty"))
		return
	
	if name.is_empty():
		_append_log(_log("log.error_sku_name_empty"))
		return
	
	if not price.is_valid_float():
		_append_log(_log("log.error_price_invalid"))
		return
	
	for sku in sku_database:
		if sku.sku_id == id:
			_append_log(_log("log.error_sku_exists", [id]))
			return
	
	var new_sku = IAPSKUData.new(id, name, price, provider, "active")
	sku_database.append(new_sku)
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	
	# 忙赂聟莽漏潞猫戮聯氓聟楼忙隆?
	sku_id_edit.text = ""
	sku_name_edit.text = ""
	sku_price_edit.text = ""
	sku_provider_option.selected = 0
	
	_append_log(_log("log.sku_added_success", [id, name]))

func _on_delete_sku():
	if not is_sku_debug_mode:
		_append_log(_log("log.debug_mode_only"))
		return
	
	_append_log(_log("log.click_delete_sku"))
	
	var selected_item = sku_tree.get_selected()
	if not selected_item:
		_append_log(_log("log.error_no_sku_selected"))
		return
	
	var item_index = selected_item.get_index()
	if item_index < 0 or item_index >= sku_database.size():
		_append_log(_log("log.error_invalid_sku_index"))
		return
	
	var deleted_sku = sku_database[item_index]
	sku_database.remove_at(item_index)
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	
	_append_log(_log("log.sku_deleted", [deleted_sku.sku_id]))

func _on_clear_sku_list():
	if not is_sku_debug_mode:
		_append_log(_log("log.debug_mode_only"))
		return
	
	_append_log(_log("log.click_clear_list"))
	
	if sku_database.is_empty():
		_append_log(_log("log.warning_list_empty"))
		return
	
	sku_database.clear()
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	
	_append_log(_log("log.sku_list_cleared"))

func _on_edit_sku():
	_append_log(_log("log.click_edit_sku"))
	
	if currently_editing_index >= 0:
		_exit_edit_mode()
		return
	
	var selected = sku_tree.get_selected()
	if not selected:
		_append_log(_log("log.warning_select_sku_first_edit"))
		return
	
	var idx = selected.get_meta("index", -1)
	if idx < 0 or idx >= sku_database.size():
		_append_log(_log("log.error_invalid_edit_index"))
		return
	
	var sku = sku_database[idx]
	
	sku_id_edit.editable = false
	sku_id_edit.text = sku.sku_id
	sku_name_edit.text = sku.sku_name
	sku_price_edit.text = sku.sku_price
	
	var provider_idx = -1
	for i in range(sku_provider_option.item_count):
		if sku_provider_option.get_item_text(i) == sku.provider:
			provider_idx = i
			break
	
	if provider_idx >= 0:
		sku_provider_option.selected = provider_idx
	
	currently_editing_index = idx
	btn_update_sku.disabled = false
	btn_add_sku.disabled = true
	btn_edit_sku.text = _t("module3.btn.exit_edit")
	
	_append_log(_log("log.enter_edit_mode", [sku.sku_id]))

func _on_update_sku():
	_append_log(_log("log.click_update_sku"))
	
	if currently_editing_index < 0 or currently_editing_index >= sku_database.size():
		_append_log(_log("log.error_invalid_edit_index"))
		_exit_edit_mode()
		return
	
	var name = sku_name_edit.text.strip_edges()
	var price = sku_price_edit.text.strip_edges()
	var provider = sku_provider_option.get_item_text(sku_provider_option.selected)
	
	if name.is_empty():
		_append_log(_log("log.error_sku_name_empty"))
		return
	
	if not price.is_valid_float():
		_append_log(_log("log.error_price_invalid"))
		return
	
	var sku = sku_database[currently_editing_index]
	var old_name = sku.sku_name
	var old_price = sku.sku_price
	var old_provider = sku.provider
	
	var has_changed = (name != old_name) or (price != old_price) or (provider != old_provider)
	
	if has_changed:
		sku.sku_name = name
		sku.sku_price = price
		sku.provider = provider
		sku.modified_time = Time.get_unix_time_from_system()
		
		if is_sku_debug_mode:
			sku.status = "active"
			sku.pending_until = 0
			_append_log(_log("log.debug_direct_update_sku_detail", [sku.sku_id]))
		else:
			if sku.status != "inactive":
				sku.status = "pending"
				sku.pending_until = Time.get_unix_time_from_system() + 7200
				_append_log(_log("log.sku_updated_pending_detail", [sku.sku_id]))
			else:
				_append_log(_log("log.sku_updated_keep_inactive_detail", [sku.sku_id]))
	else:
		_append_log(_log("log.sku_unchanged_detail", [sku.sku_id]))
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	_exit_edit_mode()

func _on_deactivate_sku():
	_append_log(_log("log.click_deactivate_sku"))
	
	var selected = sku_tree.get_selected()
	if not selected:
		_append_log(_log("log.warning_select_sku_first_deactivate"))
		return
	
	var idx = selected.get_meta("index", -1)
	if idx < 0 or idx >= sku_database.size():
		_append_log(_log("log.error_invalid_deactivate_index"))
		return
	
	var sku = sku_database[idx]
	if sku.status == "inactive":
		_append_log(_log("log.warning_sku_already_inactive", [sku.sku_id]))
		return
	
	sku.status = "inactive"
	sku.modified_time = Time.get_unix_time_from_system()
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	_exit_edit_mode()
	
	if is_sku_debug_mode:
		_append_log(_log("log.debug_direct_deactivate_sku", [sku.sku_name, sku.sku_id]))
	else:
		_append_log(_log("log.sku_deactivated_detail", [sku.sku_name, sku.sku_id]))

func _on_activate_sku():
	_append_log(_log("log.click_activate_sku"))
	
	var selected = sku_tree.get_selected()
	if not selected:
		_append_log(_log("log.warning_select_sku_first_activate"))
		return
	
	var idx = selected.get_meta("index", -1)
	if idx < 0 or idx >= sku_database.size():
		_append_log(_log("log.error_invalid_activate_index"))
		return
	
	var sku = sku_database[idx]
	if sku.status == "active":
		_append_log(_log("log.warning_sku_already_active", [sku.sku_id]))
		return
	
	sku.status = "active"
	sku.modified_time = Time.get_unix_time_from_system()
	sku.pending_until = 0
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	_exit_edit_mode()
	
	_append_log(_log("log.sku_activated_detail", [sku.sku_name, sku.sku_id]))

func _on_check_pending_status():
	var current_time = Time.get_unix_time_from_system()
	var has_changed = false
	
	for sku in sku_database:
		if sku.status == "pending" and sku.pending_until > 0 and current_time >= sku.pending_until:
			sku.status = "active"
			sku.pending_until = 0
			sku.modified_time = current_time
			has_changed = true
			_append_log(_log("log.sku_auto_activated", [sku.sku_id]))
	
	if has_changed:
		_refresh_sku_tree()
		_refresh_test_sku_option()

func _on_export_sku():
	_append_log(_log("log.click_export_sku_list"))
	
	DisplayServer.file_dialog_show(
		_t("filedialog.title.export_sku_json"),
		"",
		"sku_list.json",
		false,
		DisplayServer.FILE_DIALOG_MODE_SAVE_FILE,
		PackedStringArray(["*.json"]),
		_on_export_sku_file_selected
	)

func _on_export_sku_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int):
	if not status or selected_paths.is_empty():
		_append_log(_log("log.export_cancelled"))
		return
	
	var file_path = selected_paths[0]
	
	var export_data = []
	for sku in sku_database:
		export_data.append(sku.to_dict())
	
	var json_string = JSON.stringify(export_data, "  ")
	
	var file = FileAccess.open(file_path, FileAccess.WRITE)
	if file:
		file.store_string(json_string)
		file.close()
		_append_log(_log("log.sku_exported_to_detail", [file_path]))
	else:
		_append_log(_log("log.error_save_file_failed", [file_path]))

func _on_import_sku():
	_append_log(_log("log.click_import_sku_list"))
	
	DisplayServer.file_dialog_show(
		_t("filedialog.title.import_sku_json"),
		"",
		"",
		false,
		DisplayServer.FILE_DIALOG_MODE_OPEN_FILE,
		PackedStringArray(["*.json"]),
		_on_import_sku_file_selected
	)

func _on_import_sku_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int):
	if not status or selected_paths.is_empty():
		_append_log(_log("log.import_cancelled"))
		return
	
	var file_path = selected_paths[0]
	
	var file = FileAccess.open(file_path, FileAccess.READ)
	if not file:
		_append_log(_log("log.error_open_file_failed", [file_path]))
		return
	
	var json_string = file.get_as_text()
	file.close()
	
	var json = JSON.new()
	var parse_result = json.parse(json_string)
	if parse_result != OK:
		_append_log(_log("log.error_json_parse_failed_detail", [json.get_error_message()]))
		return
	
	var data = json.data
	if not data is Array:
		_append_log(_log("log.error_json_invalid_format"))
		return
	
	var imported_count = 0
	sku_database.clear()
	
	for item in data:
		if item is Dictionary:
			var sku = IAPSKUData.from_dict(item)
			sku_database.append(sku)
			imported_count += 1
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	
	_append_log(_log("log.sku_imported_from_detail", [file_path, imported_count]))

func _on_export_csv():
	_append_log(_log("log.click_export_csv_detail"))
	
	DisplayServer.file_dialog_show(
		"氓炉录氓聡潞SKU氓聢聴猫隆篓盲赂潞CSV",
		"",
		"sku_list.csv",
		false,
		DisplayServer.FILE_DIALOG_MODE_SAVE_FILE,
		PackedStringArray(["*.csv"]),
		_on_export_csv_file_selected
	)

func _on_export_csv_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int):
	if not status or selected_paths.is_empty():
		_append_log(_log("log.csv_export_cancelled"))
		return
	
	var file_path = selected_paths[0]
	
	var csv_content = "id,name,price,provider,status,pending_until\n"
	
	for sku in sku_database:
		csv_content += "%s,%s,%s,%s,%s,%d\n" % [
			sku.sku_id,
			sku.sku_name,
			sku.sku_price,
			sku.provider,
			sku.status,
			sku.pending_until
		]
	
	var file = FileAccess.open(file_path, FileAccess.WRITE)
	if file:
		file.store_string(csv_content)
		file.close()
		_append_log(_log("log.csv_exported_to_detail", [file_path]))
	else:
		_append_log(_log("log.error_save_csv_failed", [file_path]))

func _on_import_csv():
	_append_log(_log("log.click_import_csv_detail"))
	
	DisplayServer.file_dialog_show(
		"盲禄聨CSV氓炉录氓聟楼SKU氓聢聴猫隆篓",
		"",
		"",
		false,
		DisplayServer.FILE_DIALOG_MODE_OPEN_FILE,
		PackedStringArray(["*.csv"]),
		_on_import_csv_file_selected
	)

func _on_import_csv_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int):
	if not status or selected_paths.is_empty():
		_append_log(_log("log.csv_import_cancelled"))
		return
	
	var file_path = selected_paths[0]
	
	var file = FileAccess.open(file_path, FileAccess.READ)
	if not file:
		_append_log(_log("log.error_open_csv_failed", [file_path]))
		return
	
	var lines = file.get_as_text().split("\n")
	file.close()
	
	var imported_count = 0
	sku_database.clear()
	
	for i in range(1, lines.size()):
		var line = lines[i].strip_edges()
		if line.is_empty():
			continue
		
		var parts = line.split(",")
		if parts.size() >= 4:
			var sku_id = parts[0].strip_edges()
			var sku_name = parts[1].strip_edges()
			var sku_price = parts[2].strip_edges()
			var provider = parts[3].strip_edges() if parts.size() > 3 else "Google"
			var sku_status = parts[4].strip_edges() if parts.size() > 4 else "active"
			
			if sku_id.is_empty() or sku_name.is_empty():
				continue
			
			var sku = IAPSKUData.new(sku_id, sku_name, sku_price, provider, sku_status)
			if parts.size() > 5 and parts[5].strip_edges().is_valid_int():
				sku.pending_until = parts[5].strip_edges().to_int()
			
			sku_database.append(sku)
			imported_count += 1
	
	_refresh_sku_tree()
	_refresh_test_sku_option()
	
	_append_log(_log("log.csv_imported_from_detail", [file_path, imported_count]))

# ===================== 忙篓隆氓聺聴4茂录職忙碌聥猫炉聲忙篓隆忙聥聼氓聦潞 =====================
func _on_simulate_success():
	_append_log(_log("log.click_simulate_purchase"))
	
	if test_sku_option.selected < 0:
		_append_log(_log("log.warning_select_sku_first_purchase"))
		return
	
	var sku_index = -1
	var selected_text = test_sku_option.get_item_text(test_sku_option.selected)
	
	for i in range(sku_database.size()):
		var sku = sku_database[i]
		if selected_text.find(sku.sku_id) >= 0:
			sku_index = i
			break
	
	if sku_index >= 0:
		var sku = sku_database[sku_index]
		_append_log(_log("log.purchase_simulated_success", [sku.sku_name, sku.sku_id]))
	else:
		_append_log(_log("log.purchase_simulated"))

