		module7_huawei_order_id_edit.text = ""

func _on_test_verification():
	_append_log(_log("log.click_simulate_verify"))
	
	var provider_name = module7_provider_option.get_item_text(module7_provider_option.selected)
	var product_id = ""
	var purchase_token = ""
	var order_id = ""
	
	match module7_provider_option.selected:
		0:
			product_id = module7_product_id_edit.text.strip_edges()
			purchase_token = module7_token_edit.text.strip_edges()
			order_id = module7_order_id_edit.text.strip_edges()
		1:
			product_id = module7_apple_product_id_edit.text.strip_edges()
			purchase_token = module7_transaction_id_edit.text.strip_edges()
			order_id = module7_apple_order_id_edit.text.strip_edges()
		2:
			product_id = module7_huawei_product_id_edit.text.strip_edges()
			purchase_token = module7_huawei_token_edit.text.strip_edges()
			order_id = module7_huawei_order_id_edit.text.strip_edges()
	
	if product_id.is_empty():
		_append_log(_log("log.error_product_id_empty"))
		return
	
	if purchase_token.is_empty():
		_append_log(_log("log.error_token_empty"))
		return
	
	var token_preview = purchase_token.left(8) + "..." if purchase_token.length() > 8 else purchase_token
	
	_append_log(_log("log.simulate_verify", [product_id, token_preview, provider_name]))
	
	var response = {
		"code": 0,
		"message": "success",
		"data": {
			"product_id": product_id,
			"purchase_token": purchase_token,
			"order_id": order_id if not order_id.is_empty() else "N/A",
			"provider": provider_name,
			"verification_status": "valid",
			"purchase_state": 0,
			"consumption_state": 0,
			"timestamp": Time.get_datetime_string_from_system()
		}
	}
	
	var json_string = JSON.stringify(response, "  ")
	module7_response_text.text = json_string
	
	_append_log(_log("log.simulate_verify_detail", [product_id, token_preview]))

func _on_clear_test_response():
	_append_log(_log("log.click_clear_response"))
	module7_response_text.text = ""
	_append_log(_log("log.response_cleared"))

