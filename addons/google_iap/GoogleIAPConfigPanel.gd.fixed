func _clear_module7_inputs():
	"""忙赂聟莽漏潞忙篓隆氓聺聴 7 忙聣聙忙聹聣猫戮聯氓聟楼忙隆聠"""
	if module7_product_id_edit:
		module7_product_id_edit.text = ""
	if module7_token_edit:
		module7_token_edit.text = ""
	if module7_order_id_edit:
		module7_order_id_edit.text = ""
	if module7_apple_product_id_edit:
		module7_apple_product_id_edit.text = ""
	if module7_transaction_id_edit:
		module7_transaction_id_edit.text = ""
	if module7_original_transaction_id_edit:
		module7_original_transaction_id_edit.text = ""
	if module7_apple_order_id_edit:
		module7_apple_order_id_edit.text = ""
	if module7_huawei_product_id_edit:
		module7_huawei_product_id_edit.text = ""
	if module7_huawei_token_edit:
		module7_huawei_token_edit.text = ""
