@tool
extends ScrollContainer

# ===================== 忙聲掳忙聧庐莽禄聯忙聻聞 =====================
class IAPSKUData:
	var sku_id: String = ""
	var sku_name: String = ""
	var sku_price: String = ""
	var provider: String = "Google"
	var status: String = "active"
	var pending_until: int = 0
	var modified_time: int = 0
	
	func _init(p_id: String = "", p_name: String = "", p_price: String = "", p_provider: String = "Google", p_status: String = "active"):
		sku_id = p_id
		sku_name = p_name
		sku_price = p_price
		provider = p_provider
		status = p_status
		modified_time = Time.get_unix_time_from_system()
	
	func to_dict() -> Dictionary:
		return {
			"sku_id": sku_id,
			"sku_name": sku_name,
			"sku_price": sku_price,
			"provider": provider,
			"status": status,
			"pending_until": pending_until,
			"modified_time": modified_time
		}
	
	static func from_dict(data: Dictionary) -> IAPSKUData:
		var sku = IAPSKUData.new(
			data.get("sku_id", ""),
			data.get("sku_name", ""),
			data.get("sku_price", ""),
			data.get("provider", "Google"),
			data.get("status", "active")
		)
		sku.pending_until = data.get("pending_until", 0)
		sku.modified_time = data.get("modified_time", Time.get_unix_time_from_system())
		return sku

