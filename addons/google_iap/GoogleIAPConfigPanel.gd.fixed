# ===================== 猫戮聟氓聤漏氓聡陆忙聲掳茂录職猫麓娄忙聢路茅聟聧莽陆庐猫聨路氓聫?=====================
func _get_current_account_config() -> Dictionary:
	var selected_index = account_selector.selected
	if selected_index < 0 or selected_index >= server_accounts.size():
		return _create_default_account()
	return server_accounts[selected_index]

# ===================== 猫戮聟氓聤漏氓聡陆忙聲掳茂录職忙聹聧氓聤隆氓聲聠茅聟聧莽陆庐茅陋聦猫炉聛 =====================
func _validate_provider_config(provider: String, account_data: Dictionary) -> Dictionary:
	var errors: Array = []
	
	match provider:
		"Google Play":
			var google = account_data.get("google", {})
			if google is Dictionary:
				var package_name = str(google.get("package_name", "")).strip_edges()
				var key_path = str(google.get("key_path", "")).strip_edges()
				
				if package_name.is_empty():
					errors.append("Google Play: 氓聦聟氓聬聧盲赂聧猫聝陆盲赂潞莽漏潞")
				if key_path.is_empty():
					errors.append("Google Play: 氓炉聠茅聮楼忙聳聡盲禄露猫路炉氓戮聞盲赂聧猫聝陆盲赂潞莽漏潞")
				elif not FileAccess.file_exists(key_path):
					errors.append("Google Play: 氓炉聠茅聮楼忙聳聡盲禄露盲赂聧氓颅聵氓聹篓茂录職%s" % key_path)
		
		"Apple App Store":
			var apple = account_data.get("apple", {})
			if apple is Dictionary:
				var issuer_id = str(apple.get("issuer_id", "")).strip_edges()
				var key_id = str(apple.get("key_id", "")).strip_edges()
				var bundle_id = str(apple.get("bundle_id", "")).strip_edges()
				var key_path = str(apple.get("key_path", "")).strip_edges()
				
				if issuer_id.is_empty():
					errors.append("Apple App Store: Issuer ID 盲赂聧猫聝陆盲赂潞莽漏潞")
				if key_id.is_empty():
					errors.append("Apple App Store: Key ID 盲赂聧猫聝陆盲赂潞莽漏潞")
				if bundle_id.is_empty():
					errors.append("Apple App Store: Bundle ID 盲赂聧猫聝陆盲赂潞莽漏潞")
				if key_path.is_empty():
					errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露猫路炉氓戮聞盲赂聧猫聝陆盲赂潞莽漏潞")
				elif not FileAccess.file_exists(key_path):
					errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露盲赂聧氓颅聵氓聹篓茂录職%s" % key_path)
				elif not key_path.ends_with(".p8"):
					errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露氓驴聟茅隆禄忙聵?p8 忙聽录氓录聫")
		
		"Huawei AppGallery":
			var huawei = account_data.get("huawei", {})
			if huawei is Dictionary:
				var app_id = str(huawei.get("app_id", "")).strip_edges()
				var api_key = str(huawei.get("api_key", "")).strip_edges()
				
				if app_id.is_empty():
					errors.append("Huawei AppGallery: 氓潞聰莽聰篓 ID 盲赂聧猫聝陆盲赂潞莽漏潞")
				if api_key.is_empty():
					errors.append("Huawei AppGallery: API 氓炉聠茅聮楼盲赂聧猫聝陆盲赂潞莽漏潞")
	
	return {
		"valid": errors.is_empty(),
		"errors": errors
	}

func _on_manual_sync():
	_append_log(_log("log.click_manual_sync"))
	
	# 莽娄聛莽聰篓忙聦聣茅聮庐茅聵虏忙颅垄茅聡聧氓陇聧莽聜鹿氓聡禄
	btn_manual_sync.disabled = true
	
	# 猫聨路氓聫聳忙聹聧氓聤隆氓聲聠莽颅聸茅聙聣氓聶篓莽聤露忙聙?
	var filter_provider = ""
	if sku_provider_filter.selected > 0:
		filter_provider = sku_provider_filter.get_item_text(sku_provider_filter.selected)
	
	_append_log(_log("log.manual_sync_filter", [("氓聟篓茅聝篓" if filter_provider.is_empty() else filter_provider)]))
	
	# 猫聨路氓聫聳氓陆聯氓聣聧猫麓娄忙聢路茅聟聧莽陆庐
	var account_data = _get_current_account_config()
	
	# 忙聽鹿忙聧庐莽颅聸茅聙聣氓聶篓茅陋聦猫炉聛氓炉鹿氓潞聰莽職聞忙聹聧氓聤隆氓聲聠茅聟聧莽陆庐
	var providers_to_check = []
	if filter_provider.is_empty():
		# 莽颅聸茅聙?氓聟篓茅聝篓"茂录聦茅陋聦猫炉聛忙聣聙忙聹聣忙聹聧氓聤隆氓聲聠
		providers_to_check = ["Google Play", "Apple App Store", "Huawei AppGallery"]
	else:
		# 莽颅聸茅聙聣莽聣鹿氓庐職忙聹聧氓聤隆氓聲聠茂录聦氓聫陋茅陋聦猫炉聛猫炉楼忙聹聧氓聤隆氓聲聠
		match filter_provider:
			"Google":
				providers_to_check = ["Google Play"]
			"Apple":
				providers_to_check = ["Apple App Store"]
			"Huawei":
				providers_to_check = ["Huawei AppGallery"]
	
	# 茅陋聦猫炉聛忙聣聙忙聹聣茅聹聙猫娄聛莽職聞忙聹聧氓聤隆氓聲聠茅聟聧莽陆?
	var all_errors = []
	for provider in providers_to_check:
		var validation_result = _validate_provider_config(provider, account_data)
		if not validation_result["valid"]:
			all_errors.append_array(validation_result["errors"])
	
	# 氓娄聜忙聻聹忙聹聣茅聰聶猫炉炉茂录聦忙聵戮莽陇潞氓鹿露盲赂颅忙颅?
	if not all_errors.is_empty():
		var error_message = "忙聣聥氓聤篓氓聬聦忙颅楼氓陇卤猫麓楼茂录職茅聟聧莽陆庐盲赂聧氓庐聦忙聲麓\n" + String("\n").join(all_errors)
		validation_warning_dialog.dialog_text = error_message
		validation_warning_dialog.popup_centered()
		_append_log(_log("log.manual_sync_failed", [String("; ").join(all_errors)]))
		btn_manual_sync.disabled = false
		return
	
	# 茅陋聦猫炉聛茅聙職猫驴聡茂录聦忙聣搂猫隆聦氓聬聦忙颅?
	var current_time = Time.get_unix_time_from_system()
	var sync_count = 0
	var skipped_count = 0
	
	for sku in sku_database:
		# 忙聽鹿忙聧庐莽颅聸茅聙聣忙聺隆盲禄露猫驴聡忙禄?
		if not filter_provider.is_empty() and sku.provider != filter_provider:
			continue
		
		# 氓聫陋氓陇聞莽聬?pending 莽聤露忙聙聛莽職聞 SKU
		if sku.status == "pending":
			if sku.pending_until > 0 and current_time >= sku.pending_until:
				# 氓路虏猫露聟猫驴聡氓戮聟莽聰聼忙聲聢忙聴露茅聴麓茂录聦猫庐戮莽陆庐盲赂潞 active
				sku.status = "active"
				sku.pending_until = 0
				sku.modified_time = current_time
				sync_count += 1
				_append_log(_log("log.manual_sync_sku", [sku.sku_name, sku.sku_id]))
			else:
				# 猫驴聵忙聹陋氓聢掳莽聰聼忙聲聢忙聴露茅聴?
				skipped_count += 1
				if sku.pending_until > 0:
					var time_left = sku.pending_until - current_time
					var hours_left = int(time_left / 3600)
					var minutes_left = int((time_left % 3600) / 60)
					_append_log(_log("log.sku_not_yet_active_detail", [sku.sku_id, hours_left, minutes_left]))
				else:
					_append_log(_log("log.sku_keep_pending", [sku.sku_id]))
	
	# 氓聢路忙聳掳忙聵戮莽陇潞
	if sync_count > 0 or skipped_count > 0:
		_refresh_sku_tree()
		_refresh_test_sku_option()
	
	_append_log(_log("log.manual_sync_complete", [sync_count, skipped_count]))
	btn_manual_sync.disabled = not is_sku_debug_mode

# ===================== 忙篓隆氓聺聴6茂录職茅聟聧莽陆庐茅陋聦猫炉?=====================
func _validate_server_config() -> Dictionary:
	var errors: Array = []
	var provider_index = server_provider.selected
	
	match provider_index:
		0:
			if google_package_name.text.strip_edges().is_empty():
				errors.append("Google Play: 氓聦聟氓聬聧盲赂聧猫聝陆盲赂潞莽漏潞")
			if google_key_path.text.strip_edges().is_empty():
				errors.append("Google Play: 氓炉聠茅聮楼忙聳聡盲禄露猫路炉氓戮聞盲赂聧猫聝陆盲赂潞莽漏潞")
			elif not FileAccess.file_exists(google_key_path.text.strip_edges()):
				errors.append("Google Play: 氓炉聠茅聮楼忙聳聡盲禄露盲赂聧氓颅聵氓聹?)
		1:
			if apple_issuer_id.text.strip_edges().is_empty():
				errors.append("Apple App Store: Issuer ID盲赂聧猫聝陆盲赂潞莽漏潞")
			if apple_key_id.text.strip_edges().is_empty():
				errors.append("Apple App Store: Key ID盲赂聧猫聝陆盲赂潞莽漏潞")
			if apple_bundle_id.text.strip_edges().is_empty():
				errors.append("Apple App Store: Bundle ID盲赂聧猫聝陆盲赂潞莽漏潞")
			if apple_key_path.text.strip_edges().is_empty():
				errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露猫路炉氓戮聞盲赂聧猫聝陆盲赂潞莽漏潞")
			elif not FileAccess.file_exists(apple_key_path.text.strip_edges()):
				errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露盲赂聧氓颅聵氓聹?)
			elif not apple_key_path.text.strip_edges().ends_with(".p8"):
				errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露忙聣漏氓卤聲氓聬聧氓驴聟茅隆禄忙聵炉.p8")
		2:
			if huawei_api_key.text.strip_edges().is_empty():
				errors.append("Huawei AppGallery: API氓炉聠茅聮楼盲赂聧猫聝陆盲赂潞莽漏潞")
			if huawei_app_id.text.strip_edges().is_empty():
				errors.append("Huawei AppGallery: 氓潞聰莽聰篓ID盲赂聧猫聝陆盲赂潞莽漏潞")
	
	return {
		"valid": errors.is_empty(),
		"errors": errors
	}

func _on_save_server_config():
	_append_log(_log("log.click_save_server_config"))
	
	var validation_result = _validate_server_config()
	if not validation_result["valid"]:
		var error_message = "茅聟聧莽陆庐茅陋聦猫炉聛氓陇卤猫麓楼茂录職\n" + String("\n").join(validation_result["errors"])
		validation_warning_dialog.dialog_text = error_message
		validation_warning_dialog.popup_centered()
		_append_log(_log("log.config_save_failed_details", [String("; ").join(validation_result["errors"])]))
		return
	
	_collect_server_config()
	
	DisplayServer.file_dialog_show(
		_t("filedialog.title.save_server_config"),
		"",
		"iap_server_config.json",
		false,
		DisplayServer.FILE_DIALOG_MODE_SAVE_FILE,
		PackedStringArray(["*.json"]),
		_on_save_server_config_file_selected
	)

# ===================== 忙篓隆氓聺聴6茂录職氓陇職猫麓娄忙聢路莽庐隆莽聬聠 =====================
func _load_accounts():
	if not FileAccess.file_exists(ACCOUNTS_FILE_PATH):
		server_accounts = [_create_default_account()]
		_save_accounts()
		return
	
	var file = FileAccess.open(ACCOUNTS_FILE_PATH, FileAccess.READ)
	if not file:
		_append_log(_log("log.error_open_account_file"))
		server_accounts = [_create_default_account()]
		return
	
	var json_string = file.get_as_text()
	file.close()
	
	var json = JSON.new()
	var parse_result = json.parse(json_string)
	if parse_result != OK:
		_append_log(_log("log.error_account_file_parse_failed"))
		server_accounts = [_create_default_account()]
		return
	
	var data = json.data
	if data.has("accounts") and data["accounts"] is Array:
		server_accounts = data["accounts"]
	else:
		server_accounts = [_create_default_account()]

func _save_accounts():
	var data = {"accounts": server_accounts}
	
	var file = FileAccess.open(ACCOUNTS_FILE_PATH, FileAccess.WRITE)
	if not file:
		_append_log(_log("log.error_save_account_failed"))
		return
	
	var json = JSON.new()
	file.store_string(json.stringify(data, "\t"))
	file.close()
	_append_log(_log("log.account_data_saved"))

func _create_default_account() -> Dictionary:
	# 盲陆驴莽聰篓忙聹卢氓聹掳氓聦聳莽職聞茅禄聵猫庐陇猫麓娄忙聢路氓聬聧莽搂掳
	var default_account_name = "茅禄聵猫庐陇猫麓娄忙聢路"
	if localization_data.has("module6") and localization_data["module6"].has("default_account_name"):
		default_account_name = localization_data["module6"]["default_account_name"]
	
	return {
		"name": default_account_name,
		"provider": "Google Play",
		"google": {
			"package_name": "",
			"key_path": ""
		},
		"apple": {
			"issuer_id": "",
			"key_id": "",
			"bundle_id": "",
			"key_path": ""
		},
		"huawei": {
			"app_id": "",
			"api_key": ""
		},
		"custom": {
			"url": ""
		}
	}

func _refresh_account_selector():
	account_selector.clear()
	for account in server_accounts:
		var display_name = account["name"]
		# 氓娄聜忙聻聹忙聵炉茅禄聵猫庐陇猫麓娄忙聢路茂录聦盲陆驴莽聰篓氓陆聯氓聣聧猫炉颅猫篓聙莽職聞氓聬聧莽搂?
		if display_name == "茅禄聵猫庐陇猫麓娄忙聢路" or display_name == "Default Account":
			display_name = _t("module6.default_account_name")
		account_selector.add_item(display_name)

func _load_account_to_ui(account_index: int):
	if account_index < 0 or account_index >= server_accounts.size():
		return
	
	var account = server_accounts[account_index]
	
	var provider_text = account.get("provider", "Google Play")
	var provider_index = -1
	for i in range(server_provider.item_count):
		if server_provider.get_item_text(i) == provider_text:
			provider_index = i
			break
	
	if provider_index >= 0:
		server_provider.selected = provider_index
	else:
		server_provider.selected = 0
	
	google_config_container.visible = (server_provider.selected == 0)
	apple_config_container.visible = (server_provider.selected == 1)
	huawei_config_container.visible = (server_provider.selected == 2)
	
	var google = account.get("google", {})
	if google is Dictionary:
		google_package_name.text = google.get("package_name", "")
		google_key_path.text = google.get("key_path", "")
	
	var apple = account.get("apple", {})
	if apple is Dictionary:
		apple_issuer_id.text = apple.get("issuer_id", "")
		apple_key_id.text = apple.get("key_id", "")
		apple_bundle_id.text = apple.get("bundle_id", "")
		apple_key_path.text = apple.get("key_path", "")
	
	var huawei = account.get("huawei", {})
	if huawei is Dictionary:
		huawei_app_id.text = huawei.get("app_id", "")
		huawei_api_key.text = huawei.get("api_key", "")

func _collect_current_account() -> Dictionary:
	return {
		"name": "",
		"provider": server_provider.get_item_text(server_provider.selected),
		"google": {
			"package_name": google_package_name.text,
			"key_path": google_key_path.text
		},
		"apple": {
			"issuer_id": apple_issuer_id.text,
			"key_id": apple_key_id.text,
			"bundle_id": apple_bundle_id.text,
			"key_path": apple_key_path.text
		},
		"huawei": {
			"app_id": huawei_app_id.text,
			"api_key": huawei_api_key.text
		},
		"custom": {
			"url": ""
		}
	}

func _on_new_account():
	_append_log(_log("log.click_new_account"))
	input_dialog.title = _t("dialog.title_input")
	input_dialog.dialog_text = _t("dialog.input_account_name")
	input_field.text = ""
	input_dialog.popup_centered()
	
	input_dialog.confirmed.connect(func():
		var account_name = input_field.text.strip_edges()
		if account_name.is_empty():
			_append_log(_log("log.error_account_name_empty"))
			return
		
		var existing_index = -1
		for i in range(server_accounts.size()):
			if server_accounts[i]["name"] == account_name:
				existing_index = i
				break
		
		if existing_index >= 0:
			_append_log(_log("log.error_account_name_exists"))
			return
		
		var new_account = _collect_current_account()
		new_account["name"] = account_name
		server_accounts.append(new_account)
		_save_accounts()
		_refresh_account_selector()
		account_selector.selected = server_accounts.size() - 1
		_append_log(_log("log.account_created", [account_name]))
	)

func _on_save_account():
	var selected_index = account_selector.selected
	if selected_index < 0 or selected_index >= server_accounts.size():
		_append_log(_log("log.error_select_account_first"))
		return
	
	var account_name = server_accounts[selected_index]["name"]
	var current_data = _collect_current_account()
	current_data["name"] = account_name
	server_accounts[selected_index] = current_data
	_save_accounts()
	_append_log(_log("log.account_saved", [account_name]))

func _on_delete_account():
	var selected_index = account_selector.selected
	if selected_index < 0 or selected_index >= server_accounts.size():
		_append_log(_log("log.error_select_account_first"))
		return
	
	if server_accounts.size() <= 1:
		_append_log(_log("log.error_at_least_one_account"))
		return
	
	var account_name = server_accounts[selected_index]["name"]
	confirm_dialog.title = _t("dialog.title_confirm")
	confirm_dialog.dialog_text = _t("dialog.confirm_delete_account").format({"0": account_name})
	confirm_dialog.popup_centered()
	
	confirm_dialog.confirmed.connect(func():
		server_accounts.remove_at(selected_index)
		_save_accounts()
		_refresh_account_selector()
		if account_selector.selected < 0 and server_accounts.size() > 0:
			account_selector.selected = 0
			_load_account_to_ui(0)
		_append_log(_log("log.account_deleted", [account_name]))
	)

func _on_rename_account():
	var selected_index = account_selector.selected
	if selected_index < 0 or selected_index >= server_accounts.size():
		_append_log(_log("log.error_select_account_first"))
		return
	
	var old_name = server_accounts[selected_index]["name"]
	input_dialog.title = _t("dialog.title_input")
	input_dialog.dialog_text = _t("dialog.input_new_name")
	input_field.text = old_name
	input_dialog.popup_centered()
	
	input_dialog.confirmed.connect(func():
		var new_name = input_field.text.strip_edges()
		if new_name.is_empty():
			_append_log(_log("log.error_account_name_empty"))
			return
		
		if new_name == old_name:
			_append_log(_log("log.account_name_unchanged"))
			return
		
		var existing_index = -1
		for i in range(server_accounts.size()):
			if server_accounts[i]["name"] == new_name:
				existing_index = i
				break
		
		if existing_index >= 0:
			_append_log(_log("log.error_account_name_exists"))
			return
		
		server_accounts[selected_index]["name"] = new_name
		_save_accounts()
		_refresh_account_selector()
		account_selector.selected = selected_index
		_append_log(_log("log.account_renamed", [old_name, new_name]))
	)

func _on_account_selected(index: int):
	if index < 0 or index >= server_accounts.size():
		return
	
	var account_name = server_accounts[index]["name"]
	_append_log(_log("log.switch_account", [account_name]))
	_load_account_to_ui(index)

func _validate_account_config(account: Dictionary) -> Dictionary:
	var errors: Array = []
	var provider_text = account.get("provider", "Google Play")
	
	match provider_text:
		"Google Play":
			var google = account.get("google", {})
			if google is Dictionary:
				var package_name = str(google.get("package_name", "")).strip_edges()
				var key_path = str(google.get("key_path", "")).strip_edges()
				
				if package_name.is_empty():
					errors.append("Google Play: 氓聦聟氓聬聧盲赂聧猫聝陆盲赂潞莽漏潞")
				if key_path.is_empty():
					errors.append("Google Play: 氓炉聠茅聮楼忙聳聡盲禄露猫路炉氓戮聞盲赂聧猫聝陆盲赂潞莽漏潞")
				elif not FileAccess.file_exists(key_path):
					errors.append("Google Play: 氓炉聠茅聮楼忙聳聡盲禄露盲赂聧氓颅聵氓聹?)
		"Apple App Store":
			var apple = account.get("apple", {})
			if apple is Dictionary:
				var issuer_id = str(apple.get("issuer_id", "")).strip_edges()
				var key_id = str(apple.get("key_id", "")).strip_edges()
				var bundle_id = str(apple.get("bundle_id", "")).strip_edges()
				var key_path = str(apple.get("key_path", "")).strip_edges()
				
				if issuer_id.is_empty():
					errors.append("Apple App Store: Issuer ID盲赂聧猫聝陆盲赂潞莽漏潞")
				if key_id.is_empty():
					errors.append("Apple App Store: Key ID盲赂聧猫聝陆盲赂潞莽漏潞")
				if bundle_id.is_empty():
					errors.append("Apple App Store: Bundle ID盲赂聧猫聝陆盲赂潞莽漏潞")
				if key_path.is_empty():
					errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露猫路炉氓戮聞盲赂聧猫聝陆盲赂潞莽漏潞")
				elif not FileAccess.file_exists(key_path):
					errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露盲赂聧氓颅聵氓聹?)
				elif not key_path.ends_with(".p8"):
					errors.append("Apple App Store: 莽搂聛茅聮楼忙聳聡盲禄露氓驴聟茅隆禄忙聵?p8忙聽录氓录聫")
		"Huawei AppGallery":
			var huawei = account.get("huawei", {})
			if huawei is Dictionary:
				var app_id = str(huawei.get("app_id", "")).strip_edges()
				var api_key = str(huawei.get("api_key", "")).strip_edges()
				
				if app_id.is_empty():
					errors.append("Huawei AppGallery: 氓潞聰莽聰篓ID盲赂聧猫聝陆盲赂潞莽漏潞")
				if api_key.is_empty():
					errors.append("Huawei AppGallery: API氓炉聠茅聮楼盲赂聧猫聝陆盲赂潞莽漏潞")
	
	return {"valid": errors.is_empty(), "errors": errors}

# ===================== 猫炉颅猫篓聙莽鲁禄莽禄聼 ====================
func _setup_language_selector():
	# 氓聢聺氓搂聥氓聦聳猫炉颅猫篓聙茅聙聣忙聥漏氓聶?
	if language_selector:
		language_selector.clear()
		language_selector.add_item(_t("chinese"))
		language_selector.add_item(_t("english"))
		
		# 猫庐戮莽陆庐氓陆聯氓聣聧茅聙聣盲赂颅莽職聞猫炉颅猫篓聙
		if current_language == "en":
			language_selector.selected = 1
		else:
			language_selector.selected = 0
		
		# 猫驴聻忙聨楼盲驴隆氓聫路
		if not language_selector.item_selected.is_connected(_on_language_changed):
			language_selector.item_selected.connect(_on_language_changed)

func _load_localization(lang: String):
	_append_log(_log("log.loading_language_file", [lang]))
	var file_path = LOCALES_PATH + lang + ".json"
	_append_log(_log("log.file_path", [file_path]))
	
	if not FileAccess.file_exists(file_path):
		_append_log(_log("log.file_not_found", [file_path]))
		return
	
	_append_log(_log("log.file_exists_reading"))
	var file = FileAccess.open(file_path, FileAccess.READ)
	if not file:
		_append_log(_log("log.file_open_failed"))
		return
	
	var json_string = file.get_as_text()
	file.close()
	_append_log(_log("log.file_read_success"))
	
	var json = JSON.new()
	var parse_result = json.parse(json_string)
	if parse_result == OK:
		localization_data = json.data
		_append_log(_log("log.language_load_success", [lang]))
		# 茅陋聦猫炉聛 module7 茅聰庐忙聵炉氓聬娄氓颅聵氓聹?
		if localization_data.has("module7"):
			_append_log(_log("log.key_exists", ["module7"]))
			if localization_data.module7.has("google") and localization_data.module7.google.has("label"):
				var product_id_text = localization_data.module7.google.label.product_id
				_append_log(_log("log.key_value", ["module7.google.label.product_id", product_id_text]))
		else:
			_append_log(_log("log.key_not_found", ["module7"]))
	else:
		_append_log(_log("log.json_parse_failed", [json.get_error_message()]))

func _t(key: String) -> String:
	"""
	猫聨路氓聫聳忙聹卢氓聹掳氓聦聳忙聳聡忙聹卢茂录聦忙聰炉忙聦聛氓碌聦氓楼聴茅聰庐猫庐驴茅聴?
	盲戮聥氓娄聜茂录職_t("module1.btn.check_order") 盲录職猫庐驴茅聴?localization_data.module1.btn.check_order
	"""
	var keys = key.split(".")
	var current_data = localization_data
	
	for k in keys:
		if current_data is Dictionary and current_data.has(k):
			current_data = current_data[k]
		else:
			# 氓娄聜忙聻聹忙聣戮盲赂聧氓聢掳氓碌聦氓楼聴茅聰庐茂录聦猫驴聰氓聸聻氓聨聼氓搂聥茅聰庐盲陆聹盲赂潞茅禄聵猫庐陇氓聙?
			return key
	
	# 氓娄聜忙聻聹忙聹聙莽禄聢氓聙录忙聵炉氓颅聴莽卢娄盲赂虏茂录聦猫驴聰氓聸聻氓庐聝茂录聸氓聬娄氓聢聶猫驴聰氓聸聻茅聰庐忙聹卢猫潞?
	if current_data is String:
		return current_data
	return key

func _t_with_args(key: String, args: Array) -> String:
	"""猫聨路氓聫聳忙聹卢氓聹掳氓聦聳忙聳聡忙聹卢氓鹿露忙聽录氓录聫氓聦聳氓聫聜忙聲?""
	var text = _t(key)
	if args.size() > 0 and "%" in text:
		return text % args
	return text

func _apply_localization():
	# 氓潞聰莽聰篓忙聣聙忙聹?UI 忙聳聡忙聹卢莽職聞忙聹卢氓聹掳氓聦聳
	_append_log(_log("log.applying_localization", [current_language]))
	# 盲陆驴莽聰篓 @onready 氓聫聵茅聡聫氓聮?get_node_or_null 莽禄聯氓聬聢
	
	# ==================== 忙篓隆氓聺聴 1茂录職氓聼潞莽隆聙 IAP 忙聯聧盲陆聹氓聦?====================
	if title1:
		title1.text = _t("module1.title")
	
	var label1 = get_node_or_null("MainVBox/Module1_Basic/Row1/Label1")
	if label1:
		label1.text = _t("module1.label.test_sku") + ":"
	
	var label2 = get_node_or_null("MainVBox/Module1_Basic/Row2/Label2")
	if label2:
		label2.text = _t("module1.label.order_id") + ":"
	
	if btn_check_order:
		btn_check_order.text = _t("module1.btn.check_order")
		btn_check_order.tooltip_text = _t("module1.tooltip.btn_check_order")
	
	if btn_clear_inputs:
		btn_clear_inputs.text = _t("module1.btn.clear_inputs")
		btn_clear_inputs.tooltip_text = _t("module1.tooltip.btn_clear_inputs")
	
	# 氓聧聽盲陆聧莽卢?
	if order_id_edit:
		order_id_edit.placeholder_text = _t("module1.placeholder.order_id")
		order_id_edit.tooltip_text = _t("module1.tooltip.order_id")
	
	# 莽聤露忙聙聛忙聽聡莽颅?
	if operation_status_label:
		operation_status_label.text = _t("module1.status.waiting")
		operation_status_label.tooltip_text = _t("module1.tooltip.operation_status")
	
	# 氓路楼氓聟路忙聫聬莽陇潞
	if module1_info:
