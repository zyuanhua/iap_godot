	_append_log(_log("log.click_simulate_out_of_stock"))
	_append_log(_log("log.simulate_out_of_stock"))

func _on_simulate_cancel():
	_append_log(_log("log.click_simulate_cancel"))
	_append_log(_log("log.simulate_user_cancelled"))

func _on_reset_test():
	_append_log(_log("log.click_reset_test"))
	_append_log(_log("log.test_status_reset"))

func _on_debug_toggled(checked: bool):
	is_debug_mode = checked
