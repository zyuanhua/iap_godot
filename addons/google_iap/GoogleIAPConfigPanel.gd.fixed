# ===================== 莽聰聼氓聭陆氓聭篓忙聹聼 =====================
func _ready():
	# 茅娄聳氓聟聢氓聤聽猫陆陆猫炉颅猫篓聙氓聛聫氓楼陆
	current_language = _load_language_preference()
	
	_connect_signals()
	# 氓聟聢氓聤聽猫陆陆猫炉颅猫篓聙忙聳聡盲禄露茂录聦猫驴聶忙聽路_init_ui 盲赂颅氓聫炉盲禄楼盲陆驴莽聰篓_t()
	_load_localization(current_language)
	_init_ui()
	_init_data()
	# 氓聠聧忙卢隆氓潞聰莽聰篓忙聹卢氓聹掳氓聦聳盲禄楼莽隆庐盲驴聺忙聣聙忙聹聣忙聳聡忙聹卢忙颅拢莽隆?
	_apply_localization()
	_setup_language_selector()
	_append_log(_log("log.plugin_loaded"))
	service_status_label.text = _t("status.not_initialized")
	
	# 忙聹聙氓聬聨盲赂聙忙卢隆莽隆庐盲驴?SKU 盲赂聥忙聥聣忙隆聠茅聙聣茅隆鹿忙颅拢莽隆庐
	if sku_provider_filter:
		sku_provider_filter.clear()
		sku_provider_filter.add_item("All")
		sku_provider_filter.add_item("Google")
		sku_provider_filter.add_item("Apple")
		sku_provider_filter.add_item("Huawei")
		_append_log(_log("log.final_sku_filter_set"))

# ===================== 盲驴隆氓聫路猫驴聻忙聨楼 =====================
func _connect_signals():
	btn_check_order.pressed.connect(_on_check_order)
	btn_clear_inputs.pressed.connect(_on_clear_inputs)
	btn_init_billing.pressed.connect(_on_init_billing)
	btn_refresh_billing.pressed.connect(_on_refresh_billing)
	btn_close_billing.pressed.connect(_on_close_billing)
	
	btn_add_sku.pressed.connect(_on_add_sku)
	btn_edit_sku.pressed.connect(_on_edit_sku)
	btn_update_sku.pressed.connect(_on_update_sku)
	btn_deactivate_sku.pressed.connect(_on_deactivate_sku)
	btn_activate_sku.pressed.connect(_on_activate_sku)
	btn_import_sku.pressed.connect(_on_import_sku)
	btn_export_sku.pressed.connect(_on_export_sku)
	btn_import_csv.pressed.connect(_on_import_csv)
	btn_export_csv.pressed.connect(_on_export_csv)
	sku_provider_filter.item_selected.connect(_on_provider_filter_changed)
	show_inactive_checkbox.toggled.connect(_on_show_inactive_toggled)
	debug_mode_checkbox.toggled.connect(_on_sku_debug_mode_toggled)
	btn_manual_sync.pressed.connect(_on_manual_sync)
	status_timer.timeout.connect(_on_check_pending_status)
	sku_tree.item_selected.connect(_on_sku_selected)
	
	# SKU 莽庐隆莽聬聠忙聦聣茅聮庐茂录聢盲禄聟猫掳聝猫炉聲忙篓隆氓录聫茂录?
	btn_add_new_sku.pressed.connect(_on_add_new_sku)
	btn_delete_sku.pressed.connect(_on_delete_sku)
	btn_clear_sku_list.pressed.connect(_on_clear_sku_list)
	
	btn_simulate_success.pressed.connect(_on_simulate_success)
	btn_simulate_no_stock.pressed.connect(_on_simulate_no_stock)
	btn_simulate_cancel.pressed.connect(_on_simulate_cancel)
	btn_reset_test.pressed.connect(_on_reset_test)
	btn_clear_log.pressed.connect(_on_clear_log)
	btn_export_log.pressed.connect(_on_export_log)
	env_option.item_selected.connect(_on_env_selected)
	debug_checkbox.toggled.connect(_on_debug_toggled)
	
	btn_select_google_key.pressed.connect(_on_select_google_key)
	btn_select_apple_key.pressed.connect(_on_select_apple_key)
	btn_save_server_config.pressed.connect(_on_save_server_config)
	btn_load_server_config.pressed.connect(_on_load_server_config)
	btn_test_connection.pressed.connect(_on_test_connection)
	server_provider.item_selected.connect(_on_server_provider_selected)
	
	btn_new_account.pressed.connect(_on_new_account)
	btn_save_account.pressed.connect(_on_save_account)
	btn_delete_account.pressed.connect(_on_delete_account)
	btn_rename_account.pressed.connect(_on_rename_account)
	account_selector.item_selected.connect(_on_account_selected)
	
	module7_btn_simulate_verify.pressed.connect(_on_test_verification)
	module7_btn_clear_response.pressed.connect(_on_clear_test_response)
	module7_provider_option.item_selected.connect(_on_module7_provider_option_selected)
	
	# 猫炉颅猫篓聙茅聙聣忙聥漏氓聶篓茂录聢氓娄聜忙聻聹氓颅聵氓聹篓茂录?
	if has_node("%language_selector"):
		%language_selector.item_selected.connect(_on_language_changed)

# ===================== UI氓聢聺氓搂聥氓聦?=====================
func _init_ui():
	_append_log(_log("log.init_ui_called"))
	env_option.clear()
	env_option.add_item("忙虏聶莽聸聮莽聨炉氓垄聝 (Sandbox)")
	env_option.add_item("莽聰聼盲潞搂莽聨炉氓垄聝 (Production)")
	
	# 氓聢聺氓搂聥氓聦聳猫炉颅猫篓聙茅聙聣忙聥漏氓聶?
	if has_node("%language_selector"):
		%language_selector.clear()
		%language_selector.add_item("盲赂颅忙聳聡")
		%language_selector.add_item("English")
		%language_selector.selected = 0
	
	_append_log(_log("log.init_sku_provider_filter", [_t("module3.provider_filter_option.all")]))
	sku_provider_filter.clear()
	sku_provider_filter.add_item(_t("module3.provider_filter_option.all"))
	sku_provider_filter.add_item(_t("module3.provider_filter_option.google"))
	sku_provider_filter.add_item(_t("module3.provider_filter_option.apple"))
	sku_provider_filter.add_item(_t("module3.provider_filter_option.huawei"))
	
	sku_provider_option.clear()
	sku_provider_option.add_item(_t("module3.provider_option.google"))
	sku_provider_option.add_item(_t("module3.provider_option.apple"))
	sku_provider_option.add_item(_t("module3.provider_option.huawei"))
	
	server_provider.clear()
	server_provider.add_item(_t("module6.provider_option.google"))
	server_provider.add_item(_t("module6.provider_option.apple"))
	server_provider.add_item(_t("module6.provider_option.huawei"))
	server_provider.add_item(_t("module6.provider_option.custom"))
	
	server_env.clear()
	server_env.add_item(_t("module6.env_option.sandbox"))
	server_env.add_item(_t("module6.env_option.production"))
	
	module7_provider_option.clear()
	module7_provider_option.add_item(_t("module7.provider_option.google"))
	module7_provider_option.add_item(_t("module7.provider_option.apple"))
	module7_provider_option.add_item(_t("module7.provider_option.huawei"))
	
	google_config_container.visible = true
	apple_config_container.visible = false
	huawei_config_container.visible = false
	
	module7_google_container.visible = true
	module7_apple_container.visible = false
	module7_huawei_container.visible = false
	
	btn_manual_sync.disabled = true
	sku_id_edit.editable = true
	btn_edit_sku.text = _t("module3.btn.edit")
	
	# 氓聢聺氓搂聥氓聦?SKU 莽庐隆莽聬聠忙聦聣茅聮庐莽聤露忙聙聛茂录聢盲禄聟猫掳聝猫炉聲忙篓隆氓录聫氓聫炉莽聰篓茂录聣
	btn_add_new_sku.visible = is_sku_debug_mode
	btn_delete_sku.visible = is_sku_debug_mode
	btn_clear_sku_list.visible = is_sku_debug_mode
	btn_add_new_sku.disabled = not is_sku_debug_mode
	btn_delete_sku.disabled = not is_sku_debug_mode
	btn_clear_sku_list.disabled = not is_sku_debug_mode
	
	_load_accounts()
	_refresh_account_selector()
	if account_selector.item_count > 0:
		account_selector.selected = 0
		_load_account_to_ui(0)
	
	_init_tree()

func _init_tree():
	sku_tree.set_column_titles_visible(true)
	sku_tree.set_column_title(0, "ID")
	sku_tree.set_column_title(1, "氓聬聧莽搂掳")
	sku_tree.set_column_title(2, "盲禄路忙聽录")
	sku_tree.set_column_title(3, "忙聹聧氓聤隆氓聲?)
	sku_tree.set_column_title(4, "莽聤露忙聙?)

# ===================== 忙聲掳忙聧庐氓聢聺氓搂聥氓聦?=====================
func _init_data():
	var test_sku1 = IAPSKUData.new("com.example.gold.100", "100茅聡聭氓赂聛", "0.99", "Google", "active")
	var test_sku2 = IAPSKUData.new("com.example.gold.500", "500茅聡聭氓赂聛", "4.99", "Apple", "active")
	var test_sku3 = IAPSKUData.new("com.example.gold.1000", "1000茅聡聭氓赂聛", "9.99", "Huawei", "active")
	sku_database = [test_sku1, test_sku2, test_sku3]
	
	_refresh_sku_tree()
	_refresh_test_sku_option()

# ==================== 忙聴楼氓驴聴莽鲁禄莽禄聼 ====================
func _append_log(message: String):
	var timestamp = Time.get_datetime_string_from_system()
	log_text.text += "[%s] %s\n" % [timestamp, message]
	log_text.scroll_vertical = log_text.get_v_scroll_bar().max_value

func _append_debug_log(message: String):
	if is_debug_mode:
		var timestamp = Time.get_datetime_string_from_system()
		log_text.text += "[DEBUG] [%s] %s\n" % [timestamp, message]
		log_text.scroll_vertical = log_text.get_v_scroll_bar().max_value

func _log(key: String, args: Array = []) -> String:
	"""猫聨路氓聫聳忙聹卢氓聹掳氓聦聳忙聴楼氓驴聴忙露聢忙聛?""
	# 氓娄聜忙聻聹 key 盲赂聧盲禄楼"log."氓录聙氓陇麓茂录聦猫聡陋氓聤篓忙路禄氓聤聽氓聣聧莽录聙
	if not key.begins_with("log."):
		key = "log." + key
	return _t_with_args(key, args)

# ==================== 忙篓隆氓聺聴 1茂录職氓聼潞莽隆聙 IAP 忙聯聧盲陆聹氓聦?====================
func _on_check_order():
	_append_log(_log("log_check_order_click"))
	var order_id = order_id_edit.text.strip_edges()
	if order_id.is_empty():
		_append_log(_log("log_warning_order_id_empty"))
		operation_status_label.text = _t("order_id") + _t("status.not_initialized")
		return
	operation_status_label.text = _t("status.pending")
	await get_tree().create_timer(1).timeout
	operation_status_label.text = _t("status.success")
	_append_log(_log("log_order_query_success", [order_id]))

func _on_clear_inputs():
	_append_log(_log("log_clear_inputs_click"))
	order_id_edit.clear()
	operation_status_label.text = _t("status.cleared")
	_append_log(_log("log_inputs_cleared"))

