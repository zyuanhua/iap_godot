		var google_text = _t("module3.provider_filter_option.google")
		var apple_text = _t("module3.provider_filter_option.apple")
		var huawei_text = _t("module3.provider_filter_option.huawei")
		_append_log(_log("log.provider_filter_updating", [current_language, all_text]))
		sku_provider_filter.add_item(all_text)
		sku_provider_filter.add_item(google_text)
		sku_provider_filter.add_item(apple_text)
		sku_provider_filter.add_item(huawei_text)
		# 忙聛垄氓陇聧盲鹿聥氓聣聧莽職聞茅聙聣盲赂颅茅隆鹿茂录聦氓娄聜忙聻聹猫露聟氓聡潞猫聦聝氓聸麓氓聢聶茅聙聣盲赂颅莽卢卢盲赂聙盲赂?
		if current_selected < sku_provider_filter.item_count:
			sku_provider_filter.selected = current_selected
		else:
			sku_provider_filter.selected = 0
		_append_log(_log("log.provider_filter_options_updated", [current_language]))

func _update_env_options():
	# 忙聸麓忙聳掳莽聨炉氓垄聝盲赂聥忙聥聣忙隆?
	if server_env:
		server_env.clear()
		server_env.add_item(_t("module2.env_option.sandbox"))
		server_env.add_item(_t("module2.env_option.production"))

func _update_server_provider_options():
	# 忙聸麓忙聳掳忙聹聧氓聤隆氓聲聠盲赂聥忙聥聣忙隆聠
	if server_provider:
		server_provider.clear()
		server_provider.add_item(_t("module6.provider_option.google"))
		server_provider.add_item(_t("module6.provider_option.apple"))
		server_provider.add_item(_t("module6.provider_option.huawei"))
		server_provider.add_item(_t("module6.provider_option.custom"))


func _on_language_changed(index: int):
	if index == 0:
		current_language = "zh"
	else:
		current_language = "en"
	
	_append_log(_log("log.start_language_switch", [_t("language_name")]))
	_append_log(_log("log.current_language_code", [current_language]))
	_append_log(_log("log.locales_path", [LOCALES_PATH]))
	
	_load_localization(current_language)
	
	# 忙碌聥猫炉聲茂录職莽聸麓忙聨楼忙拢聙忙聼?localization_data 盲赂颅莽職聞氓聙?
	if localization_data.has("module3") and localization_data.module3.has("provider_filter_option"):
		_append_log(_log("log.test_direct_access", [localization_data.module3.provider_filter_option.all]))
	
	_apply_localization()
	_append_log(_log("log.ui_texts_applied"))
	
	# 氓录潞氓聢露氓聢路忙聳掳盲赂聥忙聥聣忙隆聠盲禄楼莽隆庐盲驴聺茅聙聣茅隆鹿忙聸麓忙聳掳
	if sku_provider_filter:
		# 氓聫聜猫聙?_refresh_account_selector 莽職聞忙聢聬氓聤聼忙聳鹿忙鲁聲茂录職氓庐聦氓聟篓忙赂聟莽漏潞氓鹿露茅聡聧忙聳掳忙路禄氓聤?
		var current_selected = sku_provider_filter.selected
		sku_provider_filter.clear()
		sku_provider_filter.selected = -1  # 氓聟聢忙赂聟茅聶陇茅聙聣盲赂颅莽聤露忙聙?
		
		# 茅聡聧忙聳掳忙路禄氓聤聽忙聣聙忙聹聣茅聙聣茅隆鹿
		sku_provider_filter.add_item(_t("module3.provider_filter_option.all"))
		sku_provider_filter.add_item(_t("module3.provider_filter_option.google"))
		sku_provider_filter.add_item(_t("module3.provider_filter_option.apple"))
		sku_provider_filter.add_item(_t("module3.provider_filter_option.huawei"))
		
		# 忙聛垄氓陇聧茅聙聣盲赂颅莽聤露忙聙?
		if current_selected >= 0 and current_selected < sku_provider_filter.item_count:
			sku_provider_filter.selected = current_selected
		else:
			sku_provider_filter.selected = 0
		
		_append_log(_log("log.full_refresh_dropdown", [current_language, _t("module3.provider_filter_option.all")]))
	
	_save_language_preference()
	_append_log(_log("log_language_changed", [_t("language_name")]))
	
	_append_log(_log("log.language_switch_complete"))
	
	# 盲陆驴莽聰篓 deferred 莽隆庐盲驴聺氓聹篓氓聹潞忙聶炉氓庐聦氓聟篓忙聸麓忙聳掳氓聬聨氓聠聧氓聢路忙聳掳盲赂聙忙卢?
	call_deferred("_force_refresh_dropdown")

func _force_refresh_dropdown():
	# 氓禄露猫驴聼氓聢路忙聳掳盲赂聥忙聥聣忙隆聠茂录聦莽隆庐盲驴聺氓聹篓氓聹潞忙聶炉氓庐聦氓聟篓氓聤聽猫陆陆氓聬聨忙聣搂猫隆聦
	if sku_provider_filter:
		# 氓聫聜猫聙?_refresh_account_selector 莽職聞忙聢聬氓聤聼忙聳鹿忙鲁聲茂录職氓庐聦氓聟篓忙赂聟莽漏潞氓鹿露茅聡聧忙聳掳忙路禄氓聤?
		var current_selected = sku_provider_filter.selected
		sku_provider_filter.clear()
		sku_provider_filter.selected = -1
		
		sku_provider_filter.add_item(_t("module3.provider_filter_option.all"))
		sku_provider_filter.add_item(_t("module3.provider_filter_option.google"))
		sku_provider_filter.add_item(_t("module3.provider_filter_option.apple"))
		sku_provider_filter.add_item(_t("module3.provider_filter_option.huawei"))
		
		if current_selected >= 0 and current_selected < sku_provider_filter.item_count:
			sku_provider_filter.selected = current_selected
		else:
			sku_provider_filter.selected = 0
		
		_append_log(_log("log.deferred_full_refresh", [current_language, _t("module3.provider_filter_option.all")]))

func _save_language_preference():
	# 盲驴聺氓颅聵猫炉颅猫篓聙氓聛聫氓楼陆氓聢掳茅聟聧莽陆庐忙聳聡盲禄?
	var config_path = "res://addons/google_iap/iap_config.json"
	var config = {}
	
	if FileAccess.file_exists(config_path):
		var file = FileAccess.open(config_path, FileAccess.READ)
		if file:
			var json_string = file.get_as_text()
			file.close()
			var json = JSON.new()
			if json.parse(json_string) == OK:
				config = json.data
	
	config["language"] = current_language
	
	var file = FileAccess.open(config_path, FileAccess.WRITE)
	if file:
		file.store_string(JSON.stringify(config, "  "))
		file.close()

func _load_language_preference() -> String:
	# 盲禄聨茅聟聧莽陆庐忙聳聡盲禄露氓聤聽猫陆陆猫炉颅猫篓聙氓聛聫氓楼陆
	var config_path = "res://addons/google_iap/iap_config.json"
	
	if FileAccess.file_exists(config_path):
		var file = FileAccess.open(config_path, FileAccess.READ)
		if file:
			var json_string = file.get_as_text()
			file.close()
			var json = JSON.new()
			if json.parse(json_string) == OK:
				var config = json.data
				if config.has("language"):
					return config["language"]
	
	# 茅禄聵猫庐陇猫驴聰氓聸聻盲赂颅忙聳聡
	return "zh"


