func _on_show_inactive_toggled(checked: bool):
	_append_log(_log("log.inactive_sku_display", [("开启" if checked else "关闭")]))
	_refresh_sku_tree()

func _refresh_sku_tree():
	sku_tree.clear()
	
	var filter_provider = ""
	if sku_provider_filter.selected > 0:
		filter_provider = sku_provider_filter.get_item_text(sku_provider_filter.selected)
	
	var show_inactive = show_inactive_checkbox.button_pressed
	
	for i in range(sku_database.size()):
# [TEMP DISABLED] 		var sku = sku_database[i]
		
# [TEMP DISABLED] 		if filter_provider != "" and sku.provider != filter_provider:
# [TEMP DISABLED] 			continue
		
# [TEMP DISABLED] 		if sku.status == "inactive" and not show_inactive:
# [TEMP DISABLED] 			continue
		
# [AUTO-FIX] 		var item = sku_tree.create_item()
# [TEMP DISABLED] 		item.set_text(0, sku.sku_id)
# [TEMP DISABLED] 		item.set_text(1, sku.sku_name)
# [TEMP DISABLED] 		item.set_text(2, sku.sku_price)
# [TEMP DISABLED] 		item.set_text(3, sku.provider)
# [TEMP DISABLED] 		item.set_text(4, _get_status_text(sku.status))
# [TEMP DISABLED] 		item.set_custom_color(4, _get_status_color(sku.status))
# [TEMP DISABLED] 		item.set_meta("index", i)

func _refresh_test_sku_option():
	test_sku_option.clear()
# [TEMP DISABLED] 	for sku in sku_database:
