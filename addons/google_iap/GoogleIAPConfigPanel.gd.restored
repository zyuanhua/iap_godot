func _force_refresh_dropdown():
	# 延迟刷新下拉框，确保在场景完全加载后执行
	if sku_provider_filter:
		# 参考 _refresh_account_selector 的成功方法：完全清空并重新添加
		var current_selected = sku_provider_filter.selected
		sku_provider_filter.clear()
		sku_provider_filter.selected = -1
		
		sku_provider_filter.add_item(_t("module3.provider_filter_option.all"))
# [TEMP DISABLED] 		sku_provider_filter.add_item(_t("module3.provider_filter_option.google"))
# [TEMP DISABLED] 		sku_provider_filter.add_item(_t("module3.provider_filter_option.apple"))
# [TEMP DISABLED] 		sku_provider_filter.add_item(_t("module3.provider_filter_option.huawei"))
		
		if current_selected >= 0 and current_selected < sku_provider_filter.item_count:
			sku_provider_filter.selected = current_selected
		else:
			sku_provider_filter.selected = 0
		
		_append_log(_log("log.deferred_full_refresh", [current_language, _t("module3.provider_filter_option.all")]))

func _save_language_preference():
	# 保存语言偏好到配置文件
	var config_path = "res://addons/google_iap/iap_config.json"
	var config = {}
	
	if FileAccess.file_exists(config_path):
		var file = FileAccess.open(config_path, FileAccess.READ)
		if file:
			var json_string = file.get_as_text()
			file.close()
			var json = JSON.new()
			if json.parse(json_string) == OK:
				config = json.data
	
	config["language"] = current_language
	
	var file = FileAccess.open(config_path, FileAccess.WRITE)
	if file:
		file.store_string(JSON.stringify(config, "  "))
		file.close()

func _load_language_preference() -> String:
	# 从配置文件加载语言偏好
	var config_path = "res://addons/google_iap/iap_config.json"
	
	if FileAccess.file_exists(config_path):
		var file = FileAccess.open(config_path, FileAccess.READ)
		if file:
			var json_string = file.get_as_text()
			file.close()
			var json = JSON.new()
			if json.parse(json_string) == OK:
				var config = json.data
				if config.has("language"):
					return config["language"]
	
	# 默认返回中文
	return "zh"


