# [AUTO-FIX] 	sku_name_edit.text = ""
# [AUTO-FIX] 	sku_price_edit.text = ""
# [AUTO-FIX] 	sku_provider_option.selected = 0  # 设为默认值 Google
	
	# 确保 ID 可编辑
