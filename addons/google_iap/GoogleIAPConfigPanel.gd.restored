func _on_export_log():
	_append_log(_log("log.click_export_log"))
	
	var date_str = Time.get_datetime_string_from_system().replace(" ", "_").replace(":", "-")
	var default_name = "iap_log_%s.txt" % date_str
	
	DisplayServer.file_dialog_show(
		_t("filedialog.title.export_log"),
		"",
		default_name,
		false,
		DisplayServer.FILE_DIALOG_MODE_SAVE_FILE,
		PackedStringArray(["*.txt"]),
		_on_export_log_file_selected
	)

func _on_export_log_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int):
