func _update_provider_filter_options():
	# 更新服务商筛选下拉框
	if sku_provider_filter:
		var current_selected = sku_provider_filter.selected
		sku_provider_filter.clear()
		var all_text = _t("module3.provider_filter_option.all")
# [TEMP DISABLED] 		var google_text = _t("module3.provider_filter_option.google")
# [TEMP DISABLED] 		var apple_text = _t("module3.provider_filter_option.apple")
# [TEMP DISABLED] 		var huawei_text = _t("module3.provider_filter_option.huawei")
		_append_log(_log("log.provider_filter_updating", [current_language, all_text]))
		sku_provider_filter.add_item(all_text)
		sku_provider_filter.add_item(google_text)
		sku_provider_filter.add_item(apple_text)
		sku_provider_filter.add_item(huawei_text)
		# 恢复之前的选中项，如果超出范围则选中第一个
		if current_selected < sku_provider_filter.item_count:
			sku_provider_filter.selected = current_selected
		else:
			sku_provider_filter.selected = 0
		_append_log(_log("log.provider_filter_options_updated", [current_language]))

func _update_env_options():
	# 更新环境下拉框
	if server_env:
		server_env.clear()
		server_env.add_item(_t("module2.env_option.sandbox"))
		server_env.add_item(_t("module2.env_option.production"))

func _update_server_provider_options():
	# 更新服务商下拉框
	if server_provider:
		server_provider.clear()
# [TEMP DISABLED] 		server_provider.add_item(_t("module6.provider_option.google"))
# [TEMP DISABLED] 		server_provider.add_item(_t("module6.provider_option.apple"))
# [TEMP DISABLED] 		server_provider.add_item(_t("module6.provider_option.huawei"))
		server_provider.add_item(_t("module6.provider_option.custom"))


