		btn_refresh_billing.text = _t("module2.btn.refresh_billing")
		btn_refresh_billing.tooltip_text = _t("module2.tooltip.btn_refresh_billing")
	
	if btn_close_billing:
		btn_close_billing.text = _t("module2.btn.close_billing")
		btn_close_billing.tooltip_text = _t("module2.tooltip.btn_close_billing")
	
	# 服务状态标签
	if service_status_label:
		service_status_label.text = _t("module2.service_status.uninitialized")
		service_status_label.tooltip_text = _t("module2.tooltip.service_status")
	
	# 环境下拉框
	if env_option:
		env_option.tooltip_text = _t("module2.tooltip.env")
	
	# 工具提示
	if module2_info:
		module2_info.tooltip_text = _t("module2.description")
	
	# 更新环境下拉框选项
	_update_env_options()
	
	# ==================== 模块 3：SKU 管理区 ====================
