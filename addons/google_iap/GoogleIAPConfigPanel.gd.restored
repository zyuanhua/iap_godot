# [TEMP DISABLED] 	for sku in sku_database:
# [AUTO-FIX] 		csv_content += "%s,%s,%s,%s,%s,%d\n" % [
# [TEMP DISABLED] 			sku.sku_id,
# [TEMP DISABLED] 			sku.sku_name,
# [TEMP DISABLED] 			sku.sku_price,
# [TEMP DISABLED] 			sku.provider,
