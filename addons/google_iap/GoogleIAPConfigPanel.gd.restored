# ===================== UI初始化 =====================
func _init_ui():
	_append_log(_log("log.init_ui_called"))
	env_option.clear()
	env_option.add_item("沙盒环境 (Sandbox)")
	env_option.add_item("生产环境 (Production)")
	
	# 初始化语言选择器
	if has_node("%language_selector"):
		%language_selector.clear()
		%language_selector.add_item("中文")
		%language_selector.add_item("English")
		%language_selector.selected = 0
	
	_append_log(_log("log.init_sku_provider_filter", [_t("module3.provider_filter_option.all")]))
	sku_provider_filter.clear()
	sku_provider_filter.add_item(_t("module3.provider_filter_option.all"))
# [TEMP DISABLED] 	sku_provider_filter.add_item(_t("module3.provider_filter_option.google"))
# [TEMP DISABLED] 	sku_provider_filter.add_item(_t("module3.provider_filter_option.apple"))
# [TEMP DISABLED] 	sku_provider_filter.add_item(_t("module3.provider_filter_option.huawei"))
	
	sku_provider_option.clear()
# [TEMP DISABLED] 	sku_provider_option.add_item(_t("module3.provider_option.google"))
# [TEMP DISABLED] 	sku_provider_option.add_item(_t("module3.provider_option.apple"))
# [TEMP DISABLED] 	sku_provider_option.add_item(_t("module3.provider_option.huawei"))
	
	server_provider.clear()
# [TEMP DISABLED] 	server_provider.add_item(_t("module6.provider_option.google"))
# [TEMP DISABLED] 	server_provider.add_item(_t("module6.provider_option.apple"))
# [TEMP DISABLED] 	server_provider.add_item(_t("module6.provider_option.huawei"))
	server_provider.add_item(_t("module6.provider_option.custom"))
	
	server_env.clear()
	server_env.add_item(_t("module6.env_option.sandbox"))
	server_env.add_item(_t("module6.env_option.production"))
	
# [TEMP DISABLED] 	module7_provider_option.clear()
# [TEMP DISABLED] 	module7_provider_option.add_item(_t("module7.provider_option.google"))
# [TEMP DISABLED] 	module7_provider_option.add_item(_t("module7.provider_option.apple"))
# [TEMP DISABLED] 	module7_provider_option.add_item(_t("module7.provider_option.huawei"))
	
	google_config_container.visible = true
	apple_config_container.visible = false
	huawei_config_container.visible = false
	
	module7_google_container.visible = true
	module7_apple_container.visible = false
	module7_huawei_container.visible = false
	
	btn_manual_sync.disabled = true
	sku_id_edit.editable = true
	btn_edit_sku.text = _t("module3.btn.edit")
	
	# 初始化 SKU 管理按钮状态（仅调试模式可用）
	btn_add_new_sku.visible = is_sku_debug_mode
	btn_delete_sku.visible = is_sku_debug_mode
	btn_clear_sku_list.visible = is_sku_debug_mode
	btn_add_new_sku.disabled = not is_sku_debug_mode
	btn_delete_sku.disabled = not is_sku_debug_mode
	btn_clear_sku_list.disabled = not is_sku_debug_mode
	
	_load_accounts()
	_refresh_account_selector()
	if account_selector.item_count > 0:
		account_selector.selected = 0
		_load_account_to_ui(0)
	
	_init_tree()

func _init_tree():
	sku_tree.set_column_titles_visible(true)
	sku_tree.set_column_title(0, "ID")
	sku_tree.set_column_title(1, "名称")
	sku_tree.set_column_title(2, "价格")
	sku_tree.set_column_title(3, "服务商")
	sku_tree.set_column_title(4, "状态")

# ===================== 数据初始化 =====================
func _init_data():
	var test_sku1 = IAPSKUData.new("com.example.gold.100", "100金币", "0.99", "Google", "active")
	var test_sku2 = IAPSKUData.new("com.example.gold.500", "500金币", "4.99", "Apple", "active")
	var test_sku3 = IAPSKUData.new("com.example.gold.1000", "1000金币", "9.99", "Huawei", "active")
	sku_database = [test_sku1, test_sku2, test_sku3]
	
	_refresh_sku_tree()
	_refresh_test_sku_option()

# ==================== 日志系统 ====================
func _append_log(message: String):
	var timestamp = Time.get_datetime_string_from_system()
	log_text.text += "[%s] %s\n" % [timestamp, message]
	log_text.scroll_vertical = log_text.get_v_scroll_bar().max_value

func _append_debug_log(message: String):
	if is_debug_mode:
		var timestamp = Time.get_datetime_string_from_system()
		log_text.text += "[DEBUG] [%s] %s\n" % [timestamp, message]
		log_text.scroll_vertical = log_text.get_v_scroll_bar().max_value

func _log(key: String, args: Array = []) -> String:
	"""获取本地化日志消息"""
	# 如果 key 不以"log."开头，自动添加前缀
	if not key.begins_with("log."):
		key = "log." + key
	return _t_with_args(key, args)

# ==================== 模块 1：基础 IAP 操作区 ====================
func _on_check_order():
	_append_log(_log("log_check_order_click"))
	var order_id = order_id_edit.text.strip_edges()
	if order_id.is_empty():
		_append_log(_log("log_warning_order_id_empty"))
		operation_status_label.text = _t("order_id") + _t("status.not_initialized")
		return
	operation_status_label.text = _t("status.pending")
	await get_tree().create_timer(1).timeout
	operation_status_label.text = _t("status.success")
	_append_log(_log("log_order_query_success", [order_id]))

func _on_clear_inputs():
	_append_log(_log("log_clear_inputs_click"))
	order_id_edit.clear()
	operation_status_label.text = _t("status.cleared")
	_append_log(_log("log_inputs_cleared"))

# ==================== 模块 2：计费服务控制区 ====================
# [TEMP DISABLED] func _on_env_selected(index: int):
# [TEMP DISABLED] 	var env_text = env_option.get_item_text(index)
# [TEMP DISABLED] 	_append_log(_log("log_environment_changed", [env_text]))
# [TEMP DISABLED] 	_append_debug_log(_log("log_environment_index", [index]))

func _on_init_billing():
	_append_log(_log("log_init_billing_click"))
	service_status_label.text = _t("status.initializing")
	await get_tree().create_timer(1.5).timeout
	service_status_label.text = _t("status.connected")
	_append_log(_log("log_billing_initialized"))

func _on_refresh_billing():
	_append_log(_log("log_refresh_billing_click"))
	service_status_label.text = _t("status.refreshing")
	await get_tree().create_timer(0.5).timeout
	service_status_label.text = _t("status.connected")
	_append_log(_log("log_billing_refreshed"))

func _on_close_billing():
	_append_log(_log("log_close_billing_click"))
	service_status_label.text = _t("status.disconnecting")
	await get_tree().create_timer(1).timeout
	service_status_label.text = _t("status.not_initialized")
	_append_log(_log("log_billing_closed"))
	service_status_label.text = _t("module2.service_status.uninitialized")
	_append_log(_log("log_billing_closed"))

# ===================== 模块3：SKU管理区 =====================
func _get_status_text(status: String) -> String:
	match status:
		"active":
			return "生效中"
		"inactive":
			return "已停用"
		"pending":
			return "待生效"
		_:
			return "未知"

func _get_status_color(status: String) -> Color:
	match status:
		"active":
			return Color(0, 0.8, 0)
		"inactive":
			return Color(0.8, 0, 0)
		"pending":
			return Color(0.8, 0.6, 0)
		_:
			return Color(0.5, 0.5, 0.5)

