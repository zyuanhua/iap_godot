# [AUTO-FIX] 	var new_sku = IAPSKUData.new(id, name, price, provider, "active")
# [AUTO-FIX] 	sku_database.append(new_sku)
	
# [AUTO-FIX] 	_refresh_sku_tree()
# [AUTO-FIX] 	_refresh_test_sku_option()
	
	# 清空所有输入框
