func _on_sku_debug_mode_toggled(checked: bool):
	is_sku_debug_mode = checked
	btn_manual_sync.disabled = not checked
	
	# SKU 管理按钮仅在调试模式下显示和可用
	btn_add_new_sku.visible = checked
	btn_delete_sku.visible = checked
	btn_clear_sku_list.visible = checked
	btn_add_new_sku.disabled = not checked
	btn_delete_sku.disabled = not checked
	btn_clear_sku_list.disabled = not checked
	
	_append_log(_log("log.sku_debug_mode_status", [("开启" if checked else "关闭")]))

# ===================== 辅助函数：账户配置获取 =====================
func _get_current_account_config() -> Dictionary:
	var selected_index = account_selector.selected
	if selected_index < 0 or selected_index >= server_accounts.size():
		return _create_default_account()
	return server_accounts[selected_index]

# ===================== 辅助函数：服务商配置验证 =====================
func _validate_provider_config(provider: String, account_data: Dictionary) -> Dictionary:
	var errors: Array = []
	
	match provider:
		"Google Play":
# [TEMP DISABLED] 			var google = account_data.get("google", {})
# [TEMP DISABLED] 			if google is Dictionary:
# [TEMP DISABLED] 				var package_name = str(google.get("package_name", "")).strip_edges()
# [TEMP DISABLED] 				var key_path = str(google.get("key_path", "")).strip_edges()
				
# [AUTO-FIX] 				if package_name.is_empty():
# [AUTO-FIX] 					errors.append("Google Play: 包名不能为空")
# [AUTO-FIX] 				if key_path.is_empty():
# [AUTO-FIX] 					errors.append("Google Play: 密钥文件路径不能为空")
# [AUTO-FIX] 				elif not FileAccess.file_exists(key_path):
# [AUTO-FIX] 					errors.append("Google Play: 密钥文件不存在：%s" % key_path)
		
# [AUTO-FIX] 		"Apple App Store":
# [TEMP DISABLED] 			var apple = account_data.get("apple", {})
# [TEMP DISABLED] 			if apple is Dictionary:
# [TEMP DISABLED] 				var issuer_id = str(apple.get("issuer_id", "")).strip_edges()
# [TEMP DISABLED] 				var key_id = str(apple.get("key_id", "")).strip_edges()
# [TEMP DISABLED] 				var bundle_id = str(apple.get("bundle_id", "")).strip_edges()
# [TEMP DISABLED] 				var key_path = str(apple.get("key_path", "")).strip_edges()
				
# [AUTO-FIX] 				if issuer_id.is_empty():
# [AUTO-FIX] 					errors.append("Apple App Store: Issuer ID 不能为空")
# [AUTO-FIX] 				if key_id.is_empty():
# [AUTO-FIX] 					errors.append("Apple App Store: Key ID 不能为空")
# [AUTO-FIX] 				if bundle_id.is_empty():
# [AUTO-FIX] 					errors.append("Apple App Store: Bundle ID 不能为空")
# [AUTO-FIX] 				if key_path.is_empty():
# [AUTO-FIX] 					errors.append("Apple App Store: 私钥文件路径不能为空")
# [AUTO-FIX] 				elif not FileAccess.file_exists(key_path):
# [AUTO-FIX] 					errors.append("Apple App Store: 私钥文件不存在：%s" % key_path)
# [AUTO-FIX] 				elif not key_path.ends_with(".p8"):
# [AUTO-FIX] 					errors.append("Apple App Store: 私钥文件必须是.p8 格式")
		
# [AUTO-FIX] 		"Huawei AppGallery":
# [TEMP DISABLED] 			var huawei = account_data.get("huawei", {})
# [TEMP DISABLED] 			if huawei is Dictionary:
# [TEMP DISABLED] 				var app_id = str(huawei.get("app_id", "")).strip_edges()
# [TEMP DISABLED] 				var api_key = str(huawei.get("api_key", "")).strip_edges()
				
# [AUTO-FIX] 				if app_id.is_empty():
# [AUTO-FIX] 					errors.append("Huawei AppGallery: 应用 ID 不能为空")
# [AUTO-FIX] 				if api_key.is_empty():
# [AUTO-FIX] 					errors.append("Huawei AppGallery: API 密钥不能为空")
	
# [AUTO-FIX] 	return {
# [AUTO-FIX] 		"valid": errors.is_empty(),
# [AUTO-FIX] 		"errors": errors
# [AUTO-FIX] 	}

func _on_manual_sync():
	_append_log(_log("log.click_manual_sync"))
	
	# 禁用按钮防止重复点击
	btn_manual_sync.disabled = true
	
	# 获取服务商筛选器状态
	var filter_provider = ""
	if sku_provider_filter.selected > 0:
		filter_provider = sku_provider_filter.get_item_text(sku_provider_filter.selected)
	
	_append_log(_log("log.manual_sync_filter", [("全部" if filter_provider.is_empty() else filter_provider)]))
	
	# 获取当前账户配置
	var account_data = _get_current_account_config()
	
	# 根据筛选器验证对应的服务商配置
	var providers_to_check = []
	if filter_provider.is_empty():
		# 筛选"全部"，验证所有服务商
		providers_to_check = ["Google Play", "Apple App Store", "Huawei AppGallery"]
	else:
		# 筛选特定服务商，只验证该服务商
		match filter_provider:
			"Google":
				providers_to_check = ["Google Play"]
			"Apple":
				providers_to_check = ["Apple App Store"]
			"Huawei":
				providers_to_check = ["Huawei AppGallery"]
	
	# 验证所有需要的服务商配置
	var all_errors = []
	for provider in providers_to_check:
		var validation_result = _validate_provider_config(provider, account_data)
		if not validation_result["valid"]:
			all_errors.append_array(validation_result["errors"])
	
	# 如果有错误，显示并中止
	if not all_errors.is_empty():
		var error_message = "手动同步失败：配置不完整\n" + String("\n").join(all_errors)
		validation_warning_dialog.dialog_text = error_message
		validation_warning_dialog.popup_centered()
		_append_log(_log("log.manual_sync_failed", [String("; ").join(all_errors)]))
		btn_manual_sync.disabled = false
		return
	
	# 验证通过，执行同步
	var current_time = Time.get_unix_time_from_system()
	var sync_count = 0
	var skipped_count = 0
	
# [TEMP DISABLED] 	for sku in sku_database:
		# 根据筛选条件过滤
# [TEMP DISABLED] 		if not filter_provider.is_empty() and sku.provider != filter_provider:
# [AUTO-FIX] 			continue
		
		# 只处理 pending 状态的 SKU
# [TEMP DISABLED] 		if sku.status == "pending":
# [TEMP DISABLED] 			if sku.pending_until > 0 and current_time >= sku.pending_until:
				# 已超过待生效时间，设置为 active
# [TEMP DISABLED] 				sku.status = "active"
# [TEMP DISABLED] 				sku.pending_until = 0
# [TEMP DISABLED] 				sku.modified_time = current_time
# [AUTO-FIX] 				sync_count += 1
# [TEMP DISABLED] 				_append_log(_log("log.manual_sync_sku", [sku.sku_name, sku.sku_id]))
# [AUTO-FIX] 			else:
				# 还未到生效时间
# [AUTO-FIX] 				skipped_count += 1
# [TEMP DISABLED] 				if sku.pending_until > 0:
# [TEMP DISABLED] 					var time_left = sku.pending_until - current_time
# [AUTO-FIX] 					var hours_left = int(time_left / 3600)
# [AUTO-FIX] 					var minutes_left = int((time_left % 3600) / 60)
# [TEMP DISABLED] 					_append_log(_log("log.sku_not_yet_active_detail", [sku.sku_id, hours_left, minutes_left]))
# [AUTO-FIX] 				else:
# [TEMP DISABLED] 					_append_log(_log("log.sku_keep_pending", [sku.sku_id]))
	
	# 刷新显示
# [AUTO-FIX] 	if sync_count > 0 or skipped_count > 0:
# [AUTO-FIX] 		_refresh_sku_tree()
# [AUTO-FIX] 		_refresh_test_sku_option()
	
# [AUTO-FIX] 	_append_log(_log("log.manual_sync_complete", [sync_count, skipped_count]))
# [AUTO-FIX] 	btn_manual_sync.disabled = not is_sku_debug_mode

# ===================== 模块6：配置验证 =====================
func _validate_server_config() -> Dictionary:
	var errors: Array = []
	var provider_index = server_provider.selected
	
	match provider_index:
		0:
			if google_package_name.text.strip_edges().is_empty():
				errors.append("Google Play: 包名不能为空")
			if google_key_path.text.strip_edges().is_empty():
				errors.append("Google Play: 密钥文件路径不能为空")
			elif not FileAccess.file_exists(google_key_path.text.strip_edges()):
				errors.append("Google Play: 密钥文件不存在")
		1:
			if apple_issuer_id.text.strip_edges().is_empty():
				errors.append("Apple App Store: Issuer ID不能为空")
			if apple_key_id.text.strip_edges().is_empty():
				errors.append("Apple App Store: Key ID不能为空")
			if apple_bundle_id.text.strip_edges().is_empty():
				errors.append("Apple App Store: Bundle ID不能为空")
			if apple_key_path.text.strip_edges().is_empty():
				errors.append("Apple App Store: 私钥文件路径不能为空")
			elif not FileAccess.file_exists(apple_key_path.text.strip_edges()):
				errors.append("Apple App Store: 私钥文件不存在")
			elif not apple_key_path.text.strip_edges().ends_with(".p8"):
				errors.append("Apple App Store: 私钥文件扩展名必须是.p8")
		2:
			if huawei_api_key.text.strip_edges().is_empty():
				errors.append("Huawei AppGallery: API密钥不能为空")
			if huawei_app_id.text.strip_edges().is_empty():
				errors.append("Huawei AppGallery: 应用ID不能为空")
	
	return {
		"valid": errors.is_empty(),
		"errors": errors
	}

func _on_save_server_config():
	_append_log(_log("log.click_save_server_config"))
	
	var validation_result = _validate_server_config()
	if not validation_result["valid"]:
		var error_message = "配置验证失败：\n" + String("\n").join(validation_result["errors"])
		validation_warning_dialog.dialog_text = error_message
		validation_warning_dialog.popup_centered()
		_append_log(_log("log.config_save_failed_details", [String("; ").join(validation_result["errors"])]))
		return
	
	_collect_server_config()
	
	DisplayServer.file_dialog_show(
		_t("filedialog.title.save_server_config"),
		"",
		"iap_server_config.json",
		false,
		DisplayServer.FILE_DIALOG_MODE_SAVE_FILE,
		PackedStringArray(["*.json"]),
		_on_save_server_config_file_selected
	)

# ===================== 模块6：多账户管理 =====================
func _load_accounts():
	if not FileAccess.file_exists(ACCOUNTS_FILE_PATH):
		server_accounts = [_create_default_account()]
		_save_accounts()
		return
	
	var file = FileAccess.open(ACCOUNTS_FILE_PATH, FileAccess.READ)
	if not file:
		_append_log(_log("log.error_open_account_file"))
		server_accounts = [_create_default_account()]
		return
	
	var json_string = file.get_as_text()
	file.close()
	
	var json = JSON.new()
	var parse_result = json.parse(json_string)
	if parse_result != OK:
		_append_log(_log("log.error_account_file_parse_failed"))
		server_accounts = [_create_default_account()]
		return
	
	var data = json.data
	if data.has("accounts") and data["accounts"] is Array:
		server_accounts = data["accounts"]
	else:
		server_accounts = [_create_default_account()]

func _save_accounts():
	var data = {"accounts": server_accounts}
	
	var file = FileAccess.open(ACCOUNTS_FILE_PATH, FileAccess.WRITE)
	if not file:
		_append_log(_log("log.error_save_account_failed"))
		return
	
	var json = JSON.new()
	file.store_string(json.stringify(data, "\t"))
	file.close()
	_append_log(_log("log.account_data_saved"))

func _create_default_account() -> Dictionary:
	# 使用本地化的默认账户名称
	var default_account_name = "默认账户"
	if localization_data.has("module6") and localization_data["module6"].has("default_account_name"):
		default_account_name = localization_data["module6"]["default_account_name"]
	
	return {
		"name": default_account_name,
		"provider": "Google Play",
# [TEMP DISABLED] 		"google": {
			"package_name": "",
			"key_path": ""
		},
# [TEMP DISABLED] 		"apple": {
			"issuer_id": "",
			"key_id": "",
			"bundle_id": "",
			"key_path": ""
		},
# [TEMP DISABLED] 		"huawei": {
			"app_id": "",
			"api_key": ""
		},
		"custom": {
			"url": ""
		}
	}

