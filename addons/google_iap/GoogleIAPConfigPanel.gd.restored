func _on_load_server_config():
	_append_log(_log("log.click_load_config"))
	
	DisplayServer.file_dialog_show(
		_t("filedialog.title.load_server_config"),
		"",
		"",
		false,
		DisplayServer.FILE_DIALOG_MODE_OPEN_FILE,
		PackedStringArray(["*.json"]),
		_on_load_server_config_file_selected
	)

func _on_load_server_config_file_selected(status: bool, selected_paths: PackedStringArray, _selected_filter_index: int):
	if not status or selected_paths.is_empty():
		_append_log(_log("log.load_config_cancelled"))
		return
	
	var file_path = selected_paths[0]
	
	var file = FileAccess.open(file_path, FileAccess.READ)
	if not file:
		_append_log(_log("log.error_open_config_file", [file_path]))
		return
	
	var json_string = file.get_as_text()
	file.close()
	
	var json = JSON.new()
	var parse_result = json.parse(json_string)
	if parse_result != OK:
		_append_log(_log("log.error_config_json_parse_failed", [json.get_error_message()]))
		return
	
	var data = json.data
	if not data is Dictionary:
		_append_log(_log("log.error_config_invalid_format"))
		return
	
	server_config = data
	_load_config_to_ui(server_config)
	
	if data.has("provider"):
		var provider_index = -1
		for i in range(server_provider.item_count):
			if server_provider.get_item_text(i) == data["provider"]:
				provider_index = i
				break
		if provider_index >= 0:
			server_provider.selected = provider_index
# [TEMP DISABLED] 			_on_server_provider_selected(provider_index)
	
	_append_log(_log("log.config_loaded", [file_path]))

