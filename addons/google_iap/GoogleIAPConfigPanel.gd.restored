# ===================== 生命周期 =====================
func _ready():
	# 首先加载语言偏好
	current_language = _load_language_preference()
	
	_connect_signals()
	# 先加载语言文件，这样_init_ui 中可以使用_t()
	_load_localization(current_language)
	_init_ui()
	_init_data()
	# 再次应用本地化以确保所有文本正确
	_apply_localization()
	_setup_language_selector()
	_append_log(_log("log.plugin_loaded"))
	service_status_label.text = _t("status.not_initialized")

# ===================== 信号连接 =====================
