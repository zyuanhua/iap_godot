func _on_sku_selected():
	if currently_editing_index >= 0:
		_exit_edit_mode()
	
	var selected = sku_tree.get_selected()
	if selected:
		btn_edit_sku.disabled = false
		btn_deactivate_sku.disabled = false
		btn_activate_sku.disabled = false
	else:
		btn_edit_sku.disabled = true
		btn_deactivate_sku.disabled = true
		btn_activate_sku.disabled = true

func _exit_edit_mode():
	currently_editing_index = -1
	btn_update_sku.disabled = true
	btn_add_sku.disabled = false
	btn_edit_sku.text = _t("module3.btn.edit")
	sku_id_edit.editable = true
	sku_id_edit.clear()
	sku_name_edit.clear()
	sku_price_edit.clear()
	sku_provider_option.selected = -1
	
	var selected = sku_tree.get_selected()
	if not selected:
		btn_edit_sku.disabled = true
		btn_deactivate_sku.disabled = true
		btn_activate_sku.disabled = true
	else:
		btn_edit_sku.disabled = false
		btn_deactivate_sku.disabled = false
		btn_activate_sku.disabled = false
	
	_append_log(_log("log.exit_edit_mode"))

func _on_add_sku():
	_append_log(_log("log.click_add_sku"))
	
	if currently_editing_index >= 0:
		_append_log(_log("log.exit_edit_mode"))
		_exit_edit_mode()
		return
	
	var id = sku_id_edit.text.strip_edges()
	var name = sku_name_edit.text.strip_edges()
	var price = sku_price_edit.text.strip_edges()
	var provider_index = sku_provider_option.selected
	var provider = sku_provider_option.get_item_text(provider_index) if provider_index >= 0 else "Google"
	
	if id.is_empty():
		_append_log(_log("log.error_sku_id_empty"))
		return
	
	if name.is_empty():
		_append_log(_log("log.error_sku_name_empty"))
		return
	
	if not price.is_valid_float():
		_append_log(_log("log.error_price_invalid"))
		return
	
